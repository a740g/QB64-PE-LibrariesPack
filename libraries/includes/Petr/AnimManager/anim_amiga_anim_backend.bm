    Next i
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy local pixels to pool.
' Parameters: src = source-side value or buffer reference; dstStart = working value for dst start; pixelCount = count used to size or iterate the current data set.
Sub AmgAnimCopyLocalPixelsToPool (src() As _Unsigned Long, dstStart As Long, pixelCount As Long)
    ' Variable: i stores the general-purpose loop index.
