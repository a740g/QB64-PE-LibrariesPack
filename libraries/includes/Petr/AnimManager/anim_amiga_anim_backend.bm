                If (b5 And 4) <> 0 Then color5 = color5 Or 32
                If (b6 And 4) <> 0 Then color5 = color5 Or 64
                If (b7 And 4) <> 0 Then color5 = color5 Or 128
                If (b0 And 2) <> 0 Then color6 = 1 Else color6 = 0
