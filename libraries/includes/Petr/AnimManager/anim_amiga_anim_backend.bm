                If (b4 And 128) <> 0 Then c0 = c0 Or 16
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b2 And 64) <> 0 Then c1 = c1 Or 4
                If (b3 And 64) <> 0 Then c1 = c1 Or 8
                If (b4 And 64) <> 0 Then c1 = c1 Or 16
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b2 And 32) <> 0 Then c2 = c2 Or 4
                If (b3 And 32) <> 0 Then c2 = c2 Or 8
                If (b4 And 32) <> 0 Then c2 = c2 Or 16
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
