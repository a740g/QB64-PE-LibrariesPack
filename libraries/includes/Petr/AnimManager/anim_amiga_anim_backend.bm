                If (b2 And 16) <> 0 Then c3 = c3 Or 4
                If (b3 And 16) <> 0 Then c3 = c3 Or 8
                If (b4 And 16) <> 0 Then c3 = c3 Or 16
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b2 And 8) <> 0 Then c4 = c4 Or 4
                If (b3 And 8) <> 0 Then c4 = c4 Or 8
                If (b4 And 8) <> 0 Then c4 = c4 Or 16
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b3 And 4) <> 0 Then c5 = c5 Or 8
                If (b4 And 4) <> 0 Then c5 = c5 Or 16
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b3 And 2) <> 0 Then c6 = c6 Or 8
                If (b4 And 2) <> 0 Then c6 = c6 Or 16
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4
                If (b3 And 1) <> 0 Then c7 = c7 Or 8
                If (b4 And 1) <> 0 Then c7 = c7 Or 16

                Case 6
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)
                b2 = planar(planeBase(2) + rowBase + xByte)
                b3 = planar(planeBase(3) + rowBase + xByte)
                b4 = planar(planeBase(4) + rowBase + xByte)
                b5 = planar(planeBase(5) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b1 And 128) <> 0 Then c0 = c0 Or 2
                If (b2 And 128) <> 0 Then c0 = c0 Or 4
                If (b3 And 128) <> 0 Then c0 = c0 Or 8
                If (b4 And 128) <> 0 Then c0 = c0 Or 16
                If (b5 And 128) <> 0 Then c0 = c0 Or 32
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b2 And 64) <> 0 Then c1 = c1 Or 4
                If (b3 And 64) <> 0 Then c1 = c1 Or 8
                If (b4 And 64) <> 0 Then c1 = c1 Or 16
                If (b5 And 64) <> 0 Then c1 = c1 Or 32
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b2 And 32) <> 0 Then c2 = c2 Or 4
                If (b3 And 32) <> 0 Then c2 = c2 Or 8
                If (b4 And 32) <> 0 Then c2 = c2 Or 16
                If (b5 And 32) <> 0 Then c2 = c2 Or 32
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b1 And 16) <> 0 Then c3 = c3 Or 2
                If (b2 And 16) <> 0 Then c3 = c3 Or 4
                If (b3 And 16) <> 0 Then c3 = c3 Or 8
                If (b4 And 16) <> 0 Then c3 = c3 Or 16
                If (b5 And 16) <> 0 Then c3 = c3 Or 32
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b2 And 8) <> 0 Then c4 = c4 Or 4
                If (b3 And 8) <> 0 Then c4 = c4 Or 8
                If (b4 And 8) <> 0 Then c4 = c4 Or 16
                If (b5 And 8) <> 0 Then c4 = c4 Or 32
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b3 And 4) <> 0 Then c5 = c5 Or 8
                If (b4 And 4) <> 0 Then c5 = c5 Or 16
                If (b5 And 4) <> 0 Then c5 = c5 Or 32
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b3 And 2) <> 0 Then c6 = c6 Or 8
                If (b4 And 2) <> 0 Then c6 = c6 Or 16
                If (b5 And 2) <> 0 Then c6 = c6 Or 32
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4
                If (b3 And 1) <> 0 Then c7 = c7 Or 8
                If (b4 And 1) <> 0 Then c7 = c7 Or 16
                If (b5 And 1) <> 0 Then c7 = c7 Or 32

                Case 7
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)
                b2 = planar(planeBase(2) + rowBase + xByte)
                b3 = planar(planeBase(3) + rowBase + xByte)
                b4 = planar(planeBase(4) + rowBase + xByte)
                b5 = planar(planeBase(5) + rowBase + xByte)
                b6 = planar(planeBase(6) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b1 And 128) <> 0 Then c0 = c0 Or 2
                If (b2 And 128) <> 0 Then c0 = c0 Or 4
                If (b3 And 128) <> 0 Then c0 = c0 Or 8
                If (b4 And 128) <> 0 Then c0 = c0 Or 16
                If (b5 And 128) <> 0 Then c0 = c0 Or 32
                If (b6 And 128) <> 0 Then c0 = c0 Or 64
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b2 And 64) <> 0 Then c1 = c1 Or 4
                If (b3 And 64) <> 0 Then c1 = c1 Or 8
                If (b4 And 64) <> 0 Then c1 = c1 Or 16
                If (b5 And 64) <> 0 Then c1 = c1 Or 32
                If (b6 And 64) <> 0 Then c1 = c1 Or 64
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b2 And 32) <> 0 Then c2 = c2 Or 4
                If (b3 And 32) <> 0 Then c2 = c2 Or 8
                If (b4 And 32) <> 0 Then c2 = c2 Or 16
                If (b5 And 32) <> 0 Then c2 = c2 Or 32
                If (b6 And 32) <> 0 Then c2 = c2 Or 64
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b1 And 16) <> 0 Then c3 = c3 Or 2
                If (b2 And 16) <> 0 Then c3 = c3 Or 4
                If (b3 And 16) <> 0 Then c3 = c3 Or 8
                If (b4 And 16) <> 0 Then c3 = c3 Or 16
                If (b5 And 16) <> 0 Then c3 = c3 Or 32
                If (b6 And 16) <> 0 Then c3 = c3 Or 64
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b2 And 8) <> 0 Then c4 = c4 Or 4
                If (b3 And 8) <> 0 Then c4 = c4 Or 8
                If (b4 And 8) <> 0 Then c4 = c4 Or 16
                If (b5 And 8) <> 0 Then c4 = c4 Or 32
                If (b6 And 8) <> 0 Then c4 = c4 Or 64
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b3 And 4) <> 0 Then c5 = c5 Or 8
                If (b4 And 4) <> 0 Then c5 = c5 Or 16
                If (b5 And 4) <> 0 Then c5 = c5 Or 32
                If (b6 And 4) <> 0 Then c5 = c5 Or 64
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b3 And 2) <> 0 Then c6 = c6 Or 8
                If (b4 And 2) <> 0 Then c6 = c6 Or 16
                If (b5 And 2) <> 0 Then c6 = c6 Or 32
                If (b6 And 2) <> 0 Then c6 = c6 Or 64
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4
                If (b3 And 1) <> 0 Then c7 = c7 Or 8
                If (b4 And 1) <> 0 Then c7 = c7 Or 16
                If (b5 And 1) <> 0 Then c7 = c7 Or 32
                If (b6 And 1) <> 0 Then c7 = c7 Or 64

                Case 8
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)
                b2 = planar(planeBase(2) + rowBase + xByte)
                b3 = planar(planeBase(3) + rowBase + xByte)
                b4 = planar(planeBase(4) + rowBase + xByte)
                b5 = planar(planeBase(5) + rowBase + xByte)
                b6 = planar(planeBase(6) + rowBase + xByte)
                b7 = planar(planeBase(7) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b1 And 128) <> 0 Then c0 = c0 Or 2
                If (b2 And 128) <> 0 Then c0 = c0 Or 4
                If (b3 And 128) <> 0 Then c0 = c0 Or 8
                If (b4 And 128) <> 0 Then c0 = c0 Or 16
                If (b5 And 128) <> 0 Then c0 = c0 Or 32
                If (b6 And 128) <> 0 Then c0 = c0 Or 64
                If (b7 And 128) <> 0 Then c0 = c0 Or 128
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b2 And 64) <> 0 Then c1 = c1 Or 4
                If (b3 And 64) <> 0 Then c1 = c1 Or 8
                If (b4 And 64) <> 0 Then c1 = c1 Or 16
                If (b5 And 64) <> 0 Then c1 = c1 Or 32
                If (b6 And 64) <> 0 Then c1 = c1 Or 64
                If (b7 And 64) <> 0 Then c1 = c1 Or 128
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b2 And 32) <> 0 Then c2 = c2 Or 4
                If (b3 And 32) <> 0 Then c2 = c2 Or 8
                If (b4 And 32) <> 0 Then c2 = c2 Or 16
                If (b5 And 32) <> 0 Then c2 = c2 Or 32
                If (b6 And 32) <> 0 Then c2 = c2 Or 64
                If (b7 And 32) <> 0 Then c2 = c2 Or 128
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b1 And 16) <> 0 Then c3 = c3 Or 2
                If (b2 And 16) <> 0 Then c3 = c3 Or 4
                If (b3 And 16) <> 0 Then c3 = c3 Or 8
                If (b4 And 16) <> 0 Then c3 = c3 Or 16
                If (b5 And 16) <> 0 Then c3 = c3 Or 32
                If (b6 And 16) <> 0 Then c3 = c3 Or 64
                If (b7 And 16) <> 0 Then c3 = c3 Or 128
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b2 And 8) <> 0 Then c4 = c4 Or 4
                If (b3 And 8) <> 0 Then c4 = c4 Or 8
                If (b4 And 8) <> 0 Then c4 = c4 Or 16
                If (b5 And 8) <> 0 Then c4 = c4 Or 32
                If (b6 And 8) <> 0 Then c4 = c4 Or 64
                If (b7 And 8) <> 0 Then c4 = c4 Or 128
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b3 And 4) <> 0 Then c5 = c5 Or 8
                If (b4 And 4) <> 0 Then c5 = c5 Or 16
                If (b5 And 4) <> 0 Then c5 = c5 Or 32
                If (b6 And 4) <> 0 Then c5 = c5 Or 64
                If (b7 And 4) <> 0 Then c5 = c5 Or 128
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b3 And 2) <> 0 Then c6 = c6 Or 8
                If (b4 And 2) <> 0 Then c6 = c6 Or 16
                If (b5 And 2) <> 0 Then c6 = c6 Or 32
                If (b6 And 2) <> 0 Then c6 = c6 Or 64
                If (b7 And 2) <> 0 Then c6 = c6 Or 128
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4
                If (b3 And 1) <> 0 Then c7 = c7 Or 8
                If (b4 And 1) <> 0 Then c7 = c7 Or 16
                If (b5 And 1) <> 0 Then c7 = c7 Or 32
                If (b6 And 1) <> 0 Then c7 = c7 Or 64
                If (b7 And 1) <> 0 Then c7 = c7 Or 128

                Case Else
                    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
                    ' The loop order matters because later statements expect the data to be visited sequentially.
                    For p = 0 To anim.nPlanes - 1
                        pb(p) = planar(planeBase(p) + rowBase + xByte)
                    Next p

                    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
                    ' The loop order matters because later statements expect the data to be visited sequentially.
                    For p = 0 To anim.nPlanes - 1
                        bitValue = 2 ^ p
                        If (pb(p) And 128) <> 0 Then c0 = c0 Or bitValue
                        If (pb(p) And 64) <> 0 Then c1 = c1 Or bitValue
                        If (pb(p) And 32) <> 0 Then c2 = c2 Or bitValue
                        If (pb(p) And 16) <> 0 Then c3 = c3 Or bitValue
                        If (pb(p) And 8) <> 0 Then c4 = c4 Or bitValue
                        If (pb(p) And 4) <> 0 Then c5 = c5 Or bitValue
                        If (pb(p) And 2) <> 0 Then c6 = c6 Or bitValue
                        If (pb(p) And 1) <> 0 Then c7 = c7 Or bitValue
                    Next p
            End Select

            amg_anim_scratch_pixels(baseX) = pal32(c0)
            If baseX + 1 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 1) = pal32(c1)
            If baseX + 2 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 2) = pal32(c2)
            If baseX + 3 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 3) = pal32(c3)
            If baseX + 4 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 4) = pal32(c4)
            If baseX + 5 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 5) = pal32(c5)
            If baseX + 6 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 6) = pal32(c6)
            If baseX + 7 < rowPixelLimit Then amg_anim_scratch_pixels(baseX + 7) = pal32(c7)
        Next xByte
    Next y

    frameMem = _MemImage(targetImg)
    _MemPut frameMem, frameMem.OFFSET, amg_anim_scratch_pixels()
    If _MemExists(frameMem) Then _MemFree frameMem
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation build frame by number.
' Parameters: anim = working value for animation; frames = dynamic array that stores per-frame data or cached frame metadata; pal = working value for pal; planarBase = working value for planar base; planarA = working value for planar a; planarB = working value for planar b; additional parameters continue the same pattern.
Sub AmgAnimBuildFrameByNumber (anim As AmgAnimInfo, frames() As AmgAnimFrameInfo, pal() As AmgAnimRGB8, planarBase() As _Unsigned _Byte, planarA() As _Unsigned _Byte, planarB() As _Unsigned _Byte, frameNumber As Long, chunky() As _Unsigned _Byte, ok As Long)
    ' Variable: frameIndex stores the index variable used to address the current item.
    Dim frameIndex As Long
    ' Variable: shownIsA stores the working value for shown is a.
    Dim shownIsA As Long
    ' Variable: usePrev stores the working value for use prev.
    Dim usePrev As Long

    ok = 0
    If frameNumber < 0 Then Exit Sub
    If frameNumber > anim.frameCount - 1 Then Exit Sub

    Call AmgAnimCopyPlanarBuffer(planarBase(), planarA())
    Call AmgAnimCopyPlanarBuffer(planarBase(), planarB())

    If frames(0).hasCMAP Then
        Call AmgAnimReadCMAPAt(frames(0).cmapOfs, frames(0).cmapSize, pal())
    End If

    shownIsA = -1

    If frameNumber = 0 Then
        Call AmgAnimPlanarToChunky(anim, planarA(), chunky())
        ok = -1
        Exit Sub
    End If

    ' Loop purpose: iterate through animation frames while building, seeking, or updating playback state.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For frameIndex = 1 To frameNumber
        usePrev = 0
        If frames(frameIndex).interleave = 1 Then usePrev = -1

        If shownIsA Then
            If usePrev Then
                Call AmgAnimCopyPlanarBuffer(planarA(), planarB())
            End If

            Call AmgAnimDecodeFrameToHidden(anim, frames(frameIndex), planarA(), planarB(), pal())
            shownIsA = 0
        Else
            If usePrev Then
                Call AmgAnimCopyPlanarBuffer(planarB(), planarA())
            End If

            Call AmgAnimDecodeFrameToHidden(anim, frames(frameIndex), planarB(), planarA(), pal())
            shownIsA = -1
        End If
    Next frameIndex

    If shownIsA Then
        Call AmgAnimPlanarToChunky(anim, planarA(), chunky())
    Else
        Call AmgAnimPlanarToChunky(anim, planarB(), chunky())
    End If

    ok = -1
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation get frame count internal.
' Parameters: fileName = string holding a file path or a human-readable name.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimGetFrameCountInternal& (fileName As String)
    ' Variable: anim stores the working value for animation.
    Dim anim As AmgAnimInfo
    ' dynamic array: frames is resized here to hold the dynamic array that stores per-frame data or cached frame metadata.
    ReDim frames(0) As AmgAnimFrameInfo
    ' dynamic array: pal is resized here to hold the working value for pal.
    ReDim pal(0) As AmgAnimRGB8
    ' Variable: ok stores the success flag returned by the current routine.
    Dim ok As Long

    AmgAnimGetFrameCountInternal = 0
    Call AmgAnimLoadFileToBuffer(fileName, ok)
    If ok = 0 Then Exit Function
    Call AmgAnimUseScratchBuffer

    Call AmgAnimLoadIndex(anim, frames(), pal())
    AmgAnimGetFrameCountInternal = anim.frameCount
End Function


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation extract frame image internal.
' Parameters: animId = working value for animation id; frameNumber = working value for frame number.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimExtractFrameImageInternal& (animId As Long, frameNumber As Long)
    ' Variable: img stores the QB64 image handle used to store or draw decoded pixels.
    Dim img As Long

    AmgAnimExtractFrameImageInternal = -1
    If AmgAnimValidId(animId) = 0 Then Exit Function
    If AmgAnimItems(animId).CanvasImage > -2 Then Exit Function
    If AmgAnimRenderFrameToCanvas(animId, frameNumber) = 0 Then Exit Function

    img = _CopyImage(AmgAnimItems(animId).CanvasImage, 32)
    If img > -2 Then Exit Function

    AmgAnimExtractFrameImageInternal = img
End Function



' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation alloc planar block.
' Parameters: byteCount = count used to size or iterate the current data set.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimAllocPlanarBlock& (byteCount As Long)
    ' Variable: startIndex stores the index variable used to address the current item.
    Dim startIndex As Long
    ' Variable: neededTop stores the working value for needed top.
    Dim neededTop As Long

    AmgAnimAllocPlanarBlock = -1
    If byteCount <= 0 Then Exit Function

    startIndex = amg_anim_planar_pool_used
    neededTop = startIndex + byteCount - 1

    If neededTop > UBound(amg_anim_planar_pool) Then
        ' dynamic array: amg_anim_planar_pool is resized here to hold the working value for Amiga animation planar pool.
        ReDim _Preserve amg_anim_planar_pool(neededTop) As _Unsigned _Byte
    End If

    amg_anim_planar_pool_used = startIndex + byteCount
    AmgAnimAllocPlanarBlock = startIndex
End Function

