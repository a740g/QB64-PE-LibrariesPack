                If (b3 And 8) <> 0 Then c4 = c4 Or 8
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b3 And 4) <> 0 Then c5 = c5 Or 8
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b3 And 2) <> 0 Then c6 = c6 Or 8
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4
                If (b3 And 1) <> 0 Then c7 = c7 Or 8

                Case 5
