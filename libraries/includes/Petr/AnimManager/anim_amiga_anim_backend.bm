' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation ensure scratch capacity.
' Parameters: planarSize = working value for planar size; chunkySize = working value for chunky size; palSize = working value for pal size.
Sub AmgAnimEnsureScratchCapacity (planarSize As Long, chunkySize As Long, palSize As Long)
    If planarSize > amg_anim_scratch_planar_size Then
        ' dynamic array: amg_anim_scratch_planar_base is resized here to hold the working value for Amiga animation scratch planar base.
        ReDim amg_anim_scratch_planar_base(planarSize - 1) As _Unsigned _Byte
        ' dynamic array: amg_anim_scratch_planar_a is resized here to hold the working value for Amiga animation scratch planar a.
        ReDim amg_anim_scratch_planar_a(planarSize - 1) As _Unsigned _Byte
        ' dynamic array: amg_anim_scratch_planar_b is resized here to hold the working value for Amiga animation scratch planar b.
        ReDim amg_anim_scratch_planar_b(planarSize - 1) As _Unsigned _Byte
        amg_anim_scratch_planar_size = planarSize
    End If

    If chunkySize > amg_anim_scratch_chunky_size Then
        ' dynamic array: amg_anim_scratch_chunky is resized here to hold the working value for Amiga animation scratch chunky.
        ReDim amg_anim_scratch_chunky(chunkySize - 1) As _Unsigned _Byte
        amg_anim_scratch_chunky_size = chunkySize
    End If

    If chunkySize > amg_anim_scratch_pixels_size Then
        ' dynamic array: amg_anim_scratch_pixels is resized here to hold the working value for Amiga animation scratch pixels.
        ReDim amg_anim_scratch_pixels(chunkySize - 1) As _Unsigned Long
        amg_anim_scratch_pixels_size = chunkySize
    End If

    If palSize <= 0 Then palSize = 1
    If palSize > amg_anim_scratch_pal_size Then
        ' dynamic array: amg_anim_scratch_pal is resized here to hold the working value for Amiga animation scratch pal.
        ReDim amg_anim_scratch_pal(palSize - 1) As AmgAnimRGB8
        amg_anim_scratch_pal_size = palSize
    End If
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation get stored info.
' Parameters: animId = working value for animation id; anim = working value for animation.
Sub AmgAnimGetStoredInfo (animId As Long, anim As AmgAnimInfo)
    anim.frameCount = AmgAnimItems(animId).FrameCount
    anim.w = AmgAnimItems(animId).WidthPx
    anim.h = AmgAnimItems(animId).HeightPx
    anim.nPlanes = AmgAnimItems(animId).NPlanes
    anim.rowBytes = AmgAnimItems(animId).RowBytes
    anim.planeSize = AmgAnimItems(animId).PlaneSize
    anim.compression = AmgAnimItems(animId).Compression
    anim.camg = AmgAnimItems(animId).Camg
    anim.isHAM = AmgAnimItems(animId).IsHam
    anim.firstFrameReady = -1
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy local palette to pool.
' Parameters: pal = working value for pal; dstStart = working value for dst start; colorCount = column index or color-related value.
Sub AmgAnimCopyLocalPaletteToPool (pal() As AmgAnimRGB8, dstStart As Long, colorCount As Long)
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: copyCount stores the count used to size or iterate the current data set.
    Dim copyCount As Long
    If dstStart < 0 Then Exit Sub
    copyCount = colorCount
    If copyCount <= 0 Then Exit Sub
    If copyCount > UBound(pal) + 1 Then copyCount = UBound(pal) + 1
    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To copyCount - 1
        amg_anim_palette_pool(dstStart + i) = pal(i)
    Next i
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy pool palette to local.
' Parameters: srcStart = working value for src start; colorCount = column index or color-related value; pal = working value for pal.
Sub AmgAnimCopyPoolPaletteToLocal (srcStart As Long, colorCount As Long, pal() As AmgAnimRGB8)
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    If colorCount <= 0 Then
        ' dynamic array: pal is resized here to hold the working value for pal.
        ReDim pal(0) As AmgAnimRGB8
        Exit Sub
    End If
    ' dynamic array: pal is resized here to hold the working value for pal.
    ReDim pal(colorCount - 1) As AmgAnimRGB8
    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To colorCount - 1
        pal(i) = amg_anim_palette_pool(srcStart + i)
    Next i
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy local planar to pool.
' Parameters: src = source-side value or buffer reference; dstStart = working value for dst start; byteCount = count used to size or iterate the current data set.
Sub AmgAnimCopyLocalPlanarToPool (src() As _Unsigned _Byte, dstStart As Long, byteCount As Long)
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    If dstStart < 0 Then Exit Sub
    If byteCount <= 0 Then Exit Sub
    ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To byteCount - 1
        amg_anim_planar_pool(dstStart + i) = src(i)
    Next i
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy pool planar to local.
' Parameters: srcStart = working value for src start; byteCount = count used to size or iterate the current data set; dst = destination-side value or buffer reference.
Sub AmgAnimCopyPoolPlanarToLocal (srcStart As Long, byteCount As Long, dst() As _Unsigned _Byte)
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    If byteCount <= 0 Then Exit Sub
    ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To byteCount - 1
        dst(i) = amg_anim_planar_pool(srcStart + i)
    Next i
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy local chunky to pool.
' Parameters: src = source-side value or buffer reference; dstStart = working value for dst start; byteCount = count used to size or iterate the current data set.
