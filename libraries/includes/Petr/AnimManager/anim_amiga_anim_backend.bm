                If (b2 And 2) <> 0 Then color6 = color6 Or 4
                If (b3 And 2) <> 0 Then color6 = color6 Or 8
                If (b4 And 2) <> 0 Then color6 = color6 Or 16
                If (b5 And 2) <> 0 Then color6 = color6 Or 32
