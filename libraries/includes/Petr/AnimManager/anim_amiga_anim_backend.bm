                If (b4 And 1) <> 0 Then color7 = color7 Or 16
                If (b5 And 1) <> 0 Then color7 = color7 Or 32
                If (b6 And 1) <> 0 Then color7 = color7 Or 64
                If (b7 And 1) <> 0 Then color7 = color7 Or 128

                Case Else
                    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
                    ' The loop order matters because later statements expect the data to be visited sequentially.
                    For p = 0 To anim.nPlanes - 1
                        pb(p) = planar(planeBase(p) + rowBase + xByte)
                    Next p

                    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
                    ' The loop order matters because later statements expect the data to be visited sequentially.
                    For p = 0 To anim.nPlanes - 1
                        bitValue = 2 ^ p
                        If (pb(p) And 128) <> 0 Then color0 = color0 Or bitValue
                        If (pb(p) And 64) <> 0 Then color1 = color1 Or bitValue
                        If (pb(p) And 32) <> 0 Then color2 = color2 Or bitValue
                        If (pb(p) And 16) <> 0 Then color3 = color3 Or bitValue
                        If (pb(p) And 8) <> 0 Then color4 = color4 Or bitValue
                        If (pb(p) And 4) <> 0 Then color5 = color5 Or bitValue
                        If (pb(p) And 2) <> 0 Then color6 = color6 Or bitValue
                        If (pb(p) And 1) <> 0 Then color7 = color7 Or bitValue
                    Next p
            End Select

            chunky(baseX) = color0
            If baseX + 1 < rowPixelLimit Then chunky(baseX + 1) = color1
            If baseX + 2 < rowPixelLimit Then chunky(baseX + 2) = color2
            If baseX + 3 < rowPixelLimit Then chunky(baseX + 3) = color3
            If baseX + 4 < rowPixelLimit Then chunky(baseX + 4) = color4
            If baseX + 5 < rowPixelLimit Then chunky(baseX + 5) = color5
            If baseX + 6 < rowPixelLimit Then chunky(baseX + 6) = color6
            If baseX + 7 < rowPixelLimit Then chunky(baseX + 7) = color7
        Next xByte
    Next y
End Sub


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs; limitOfs = working value for limit ofs; ck = working value for ck; ok = success flag returned by the current routine.
Sub AmgAnimReadIffChunk (bufOfs As _Unsigned _Integer64, limitOfs As _Unsigned _Integer64, ck As AmgAnimIffChunkInfo, ok As Long)
    ' Variable: here stores the working value for here.
    Dim here As _Unsigned _Integer64
    ' Variable: sizeValue stores the working value for size value.
    Dim sizeValue As _Unsigned Long

    here = bufOfs

    If here + 8 > limitOfs Or here + 8 > AmgAnimActiveSize Then
        ok = 0
        Exit Sub
    End If

    ck.id = AmgAnimReadIDFromBuf$(bufOfs)
    Call AmgAnimReadU32BE(bufOfs, sizeValue)

    ck.size = sizeValue
    ck.dataOfs = bufOfs
    ck.nextOfs = AmgAnimAlign2(ck.dataOfs + ck.size)

    If ck.nextOfs > limitOfs Or ck.nextOfs > AmgAnimActiveSize Then
        ok = 0
        Exit Sub
    End If

    ok = -1
End Sub


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs; value = working value for value.
Sub AmgAnimReadByte (bufOfs As _Unsigned _Integer64, value As _Unsigned _Byte)
    value = AmgAnimGetActiveByte(bufOfs)
    bufOfs = bufOfs + 1
End Sub


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs; value = working value for value.
Sub AmgAnimReadU16BE (bufOfs As _Unsigned _Integer64, value As Long)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Unsigned _Byte
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Unsigned _Byte

    Call AmgAnimReadByte(bufOfs, b0)
    Call AmgAnimReadByte(bufOfs, b1)

    value = b0 * 256 + b1
End Sub


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs; value = working value for value.
Sub AmgAnimReadS16BE (bufOfs As _Unsigned _Integer64, value As Long)
    ' Variable: temp stores the temporary scratch value.
    Dim temp As Long

    Call AmgAnimReadU16BE(bufOfs, temp)

    If temp >= 32768 Then
        value = temp - 65536
    Else
        value = temp
    End If
End Sub


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs; value = working value for value.
Sub AmgAnimReadU32BE (bufOfs As _Unsigned _Integer64, value As _Unsigned Long)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Unsigned _Byte
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Unsigned _Byte
    ' Variable: b2 stores the working value for b 2.
    Dim b2 As _Unsigned _Byte
    ' Variable: b3 stores the working value for b 3.
    Dim b3 As _Unsigned _Byte

    Call AmgAnimReadByte(bufOfs, b0)
    Call AmgAnimReadByte(bufOfs, b1)
    Call AmgAnimReadByte(bufOfs, b2)
    Call AmgAnimReadByte(bufOfs, b3)

    value = b0
    value = value * 256 + b1
    value = value * 256 + b2
    value = value * 256 + b3
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation chunk data end.
' Parameters: dataOfs = buffer that holds raw, packed, or decoded byte data; size = size value for the current block, buffer, or file.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimChunkDataEnd&& (dataOfs As _Unsigned _Integer64, size As _Unsigned Long)
    AmgAnimChunkDataEnd&& = dataOfs + size
End Function


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation align 2.
' Parameters: value = working value for value.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimAlign2&& (value As _Unsigned _Integer64)
    If (value And 1) <> 0 Then
        AmgAnimAlign2&& = value + 1
    Else
        AmgAnimAlign2&& = value
    End If
End Function


' Purpose: Read IFF/ANIM chunks and build decoder state for the Amiga animation.
' Parameters: bufOfs = working value for buf ofs.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimReadIDFromBuf$ (bufOfs As _Unsigned _Integer64)
    ' Variable: result stores the working value for result.
    Dim result As String
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: b stores the color component or packed color helper used during image conversion.
    Dim b As _Unsigned _Byte

    result = Space$(4)
    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 1 To 4
        Call AmgAnimReadByte(bufOfs, b)
        Mid$(result, i, 1) = Chr$(b)
    Next i
    AmgAnimReadIDFromBuf$ = result
End Function


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation unpack byte run 1 row.
' Parameters: bufOfs = working value for buf ofs; bodyEnd = working value for body end; rowBuf = buffer that holds raw, packed, or decoded byte data; rowLen = row pointer, row buffer, or row index used for image processing.
Sub AmgAnimUnpackByteRun1Row (bufOfs As _Unsigned _Integer64, bodyEnd As _Unsigned _Integer64, rowBuf() As _Unsigned _Byte, rowLen As Long)
    ' Variable: ctrl stores the working value for ctrl.
    Dim ctrl As _Unsigned _Byte
    ' Variable: literalCount stores the count used to size or iterate the current data set.
    Dim literalCount As Long
    ' Variable: repeatCount stores the count used to size or iterate the current data set.
    Dim repeatCount As Long
    ' Variable: dst stores the destination-side value or buffer reference.
    Dim dst As Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: valueByte stores the working value for value byte.
    Dim valueByte As _Unsigned _Byte
    ' Variable: storeCount stores the count used to size or iterate the current data set.
    Dim storeCount As Long

    dst = 0

    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While dst < rowLen
        If bufOfs >= bodyEnd Then Exit Do

        Call AmgAnimReadByte(bufOfs, ctrl)

        If ctrl <= 127 Then
            literalCount = ctrl + 1
            storeCount = literalCount
            If dst + storeCount > rowLen Then
                storeCount = rowLen - dst
            End If

            ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For i = 1 To literalCount
                If bufOfs >= bodyEnd Then Exit For
                Call AmgAnimReadByte(bufOfs, valueByte)
                If i <= storeCount Then
                    rowBuf(dst) = valueByte
                    dst = dst + 1
                End If
            Next i

        ElseIf ctrl = 128 Then
            ' NOP

        Else
            repeatCount = 257 - ctrl
            storeCount = repeatCount
            If dst + storeCount > rowLen Then
                storeCount = rowLen - dst
            End If

            If bufOfs >= bodyEnd Then Exit Do
            Call AmgAnimReadByte(bufOfs, valueByte)

            ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For i = 1 To storeCount
                rowBuf(dst) = valueByte
                dst = dst + 1
            Next i
        End If
    Loop

    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While dst < rowLen
        rowBuf(dst) = 0
        dst = dst + 1
    Loop
End Sub


' Purpose: Decode or apply Amiga ANIM delta/frame data to the current bitmap.
' Parameters: anim = working value for animation; bodyOfs = working value for body ofs; bodySize = working value for body size; compression = working value for compression; planar = working value for planar.
Sub AmgAnimDecodeILBMBodyToPlanar (anim As AmgAnimInfo, bodyOfs As _Unsigned _Integer64, bodySize As _Unsigned Long, compression As Long, planar() As _Unsigned _Byte)
    ' Variable: totalPlanar stores the working value for total planar.
    Dim totalPlanar As Long
    ' Variable: planeBase stores the working value for plane base.
    Dim planeBase As Long
    ' Variable: destOfs stores the working value for dest ofs.
    Dim destOfs As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: p stores the generic pointer or position value.
    Dim p As Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: b stores the color component or packed color helper used during image conversion.
    Dim b As _Unsigned _Byte
    ' Variable: bodyEnd stores the working value for body end.
    Dim bodyEnd As _Unsigned _Integer64
    ' Variable: bufOfs stores the working value for buf ofs.
    Dim bufOfs As _Unsigned _Integer64
    ' Variable: planarMem stores the memory handle or memory-related helper value.
    Dim planarMem As _MEM
    ' dynamic array: rowBuf is resized here to hold the buffer that holds raw, packed, or decoded byte data.
    ReDim rowBuf(0) As _Unsigned _Byte

    totalPlanar = anim.rowBytes * anim.h * anim.nPlanes
    bodyEnd = bodyOfs + bodySize
    bufOfs = bodyOfs

    If anim.rowBytes <= 0 Then Exit Sub
    ' dynamic array: rowBuf is resized here to hold the buffer that holds raw, packed, or decoded byte data.
    ReDim rowBuf(anim.rowBytes - 1) As _Unsigned _Byte

    If compression = 0 Then
        ' Loop purpose: iterate through image rows or vertical positions.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For y = 0 To anim.h - 1
            ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For p = 0 To anim.nPlanes - 1
                planeBase = p * anim.planeSize
                destOfs = planeBase + y * anim.rowBytes

                ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For i = 0 To anim.rowBytes - 1
                    If bufOfs >= bodyEnd Then
'                         Print "BODY ends too early."
                        Exit Sub
                    End If

                    Call AmgAnimReadByte(bufOfs, b)
                    planar(destOfs + i) = b
                Next i
            Next p
        Next y

    ElseIf compression = 1 Then
        planarMem = _Mem(planar())

        ' Loop purpose: iterate through image rows or vertical positions.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For y = 0 To anim.h - 1
            ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For p = 0 To anim.nPlanes - 1
                planeBase = p * anim.planeSize
                destOfs = planeBase + y * anim.rowBytes

                Call AmgAnimUnpackByteRun1Row(bufOfs, bodyEnd, rowBuf(), anim.rowBytes)
                _MemPut planarMem, planarMem.OFFSET + destOfs, rowBuf()
            Next p
        Next y

        If _MemExists(planarMem) Then _MemFree planarMem
    Else
'         Print "Unsupported BODY compression:"; compression
    End If
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation validate first frame bmhd.
' Parameters: ilbm = working value for ILBM; ok = success flag returned by the current routine.
Sub AmgAnimValidateFirstFrameBMHD (ilbm As AmgAnimIlbmInfo, ok As Long)
    ok = -1

    If ilbm.w <= 0 Or ilbm.h <= 0 Then
'         Print "Invalid BMHD size."
        ok = 0
        Exit Sub
    End If

    If ilbm.nPlanes < 1 Or ilbm.nPlanes > 8 Then
'         Print "Only 1..8 bitplanes are supported."
        ok = 0
        Exit Sub
    End If

    If ilbm.masking <> 0 Then
'         Print "Mask plane is not supported in this build."
        ok = 0
        Exit Sub
    End If

    If ilbm.compression <> 0 And ilbm.compression <> 1 Then
'         Print "Only BODY compression 0 and 1 are supported."
        ok = 0
        Exit Sub
    End If
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation validate frame anhd.
' Parameters: anhd = working value for anhd; ok = success flag returned by the current routine.
Sub AmgAnimValidateFrameANHD (anhd As AmgAnimAnhdInfo, ok As Long)
    ok = -1

    If anhd.valid = 0 Then
'         Print "ANHD missing or invalid."
        ok = 0
        Exit Sub
    End If

    If anhd.operation <> 0 And anhd.operation <> 5 And anhd.operation <> 7 Then
'         Print "Only ANHD operation 0, 5 and 7 are supported."
        ok = 0
        Exit Sub
    End If

    ' Real-world op5/op7 files may carry non-zero bits or interleave metadata.
    ' Do not reject them during indexing.
End Sub


' Purpose: Decode or apply Amiga ANIM delta/frame data to the current bitmap.
' Parameters: anim = working value for animation; dltaOfs = working value for dlta ofs; dltaSize = working value for dlta size; planar = working value for planar.
Sub AmgAnimApplyDLTAOp5 (anim As AmgAnimInfo, dltaOfs As _Unsigned _Integer64, dltaSize As _Unsigned Long, planar() As _Unsigned _Byte)
    ' Array: ptrTable stores the working value for ptr table.
    Dim ptrTable(15) As _Unsigned Long
    ' Variable: p stores the generic pointer or position value.
    Dim p As Long
    ' Variable: col stores the column index or color-related value.
    Dim col As Long
    ' Variable: opCount stores the count used to size or iterate the current data set.
    Dim opCount As Long
    ' Variable: opCode stores the working value for op code.
    Dim opCode As Long
    ' Variable: runCount stores the count used to size or iterate the current data set.
    Dim runCount As Long
    ' Variable: srcOfs stores the working value for src ofs.
    Dim srcOfs As _Unsigned _Integer64
    ' Variable: planeBase stores the working value for plane base.
    Dim planeBase As Long
    ' Variable: planeEnd stores the working value for plane end.
    Dim planeEnd As Long
    ' Variable: colEnd stores the column index or color-related value.
    Dim colEnd As Long
    ' Variable: dstOfs stores the working value for dst ofs.
    Dim dstOfs As Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: b stores the color component or packed color helper used during image conversion.
    Dim b As _Unsigned _Byte
    ' Variable: valueByte stores the working value for value byte.
    Dim valueByte As _Unsigned _Byte
    ' Variable: bufOfs stores the working value for buf ofs.
    Dim bufOfs As _Unsigned _Integer64
    ' Variable: dltaEnd stores the working value for dlta end.
    Dim dltaEnd As _Unsigned _Integer64

    dltaEnd = dltaOfs + dltaSize
    bufOfs = dltaOfs

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 15
        ptrTable(i) = 0
    Next i

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 15
        Call AmgAnimReadU32BE(bufOfs, ptrTable(i))
    Next i

    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For p = 0 To anim.nPlanes - 1
        If ptrTable(p) <> 0 Then
            srcOfs = dltaOfs + ptrTable(p)
            If srcOfs >= dltaEnd Then
'                 Print "DLTA op5 pointer outside chunk."
                Exit Sub
            End If

            planeBase = p * anim.planeSize
            planeEnd = planeBase + anim.planeSize
            bufOfs = srcOfs

            ' Loop purpose: iterate through image columns, pixels, or horizontal positions.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For col = 0 To anim.rowBytes - 1
                Call AmgAnimReadByte(bufOfs, b)
                opCount = b
                dstOfs = planeBase + col
                colEnd = planeEnd + col

                ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For i = 1 To opCount
                    Call AmgAnimReadByte(bufOfs, b)
                    opCode = b

                    If opCode = 0 Then
                        Call AmgAnimReadByte(bufOfs, b)
                        runCount = b
                        Call AmgAnimReadByte(bufOfs, valueByte)

                        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
                        Do While runCount > 0
                            If dstOfs < planeBase Or dstOfs >= planeEnd Then
'                                 Print "DLTA op5 SAME overruns plane."
                                Exit Sub
                            End If

                            planar(dstOfs) = valueByte
                            dstOfs = dstOfs + anim.rowBytes
                            runCount = runCount - 1
                        Loop

                    ElseIf (opCode And &H80) <> 0 Then
                        runCount = opCode And &H7F

                        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
                        Do While runCount > 0
                            If dstOfs < planeBase Or dstOfs >= planeEnd Then
'                                 Print "DLTA op5 UNIQ overruns plane."
                                Exit Sub
                            End If

                            Call AmgAnimReadByte(bufOfs, valueByte)
                            planar(dstOfs) = valueByte
                            dstOfs = dstOfs + anim.rowBytes
                            runCount = runCount - 1
                        Loop

                    Else
                        dstOfs = dstOfs + opCode * anim.rowBytes

                        If dstOfs > colEnd Then
'                             Print "DLTA op5 SKIP overruns plane column."
                            Exit Sub
                        End If
                    End If
                Next i
            Next col
        End If
    Next p
End Sub


' Purpose: Decode or apply Amiga ANIM delta/frame data to the current bitmap.
' Parameters: anim = working value for animation; dltaOfs = working value for dlta ofs; dltaSize = working value for dlta size; anhdBits = working value for anhd bits; planar = working value for planar.
Sub AmgAnimApplyDLTAOp7 (anim As AmgAnimInfo, dltaOfs As _Unsigned _Integer64, dltaSize As _Unsigned Long, anhdBits As _Unsigned Long, planar() As _Unsigned _Byte)
    ' Array: opPtrTable stores the working value for op ptr table.
    Dim opPtrTable(7) As _Unsigned Long
    ' Array: dataPtrTable stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataPtrTable(7) As _Unsigned Long
    ' Variable: p stores the generic pointer or position value.
    Dim p As Long
    ' Variable: col stores the column index or color-related value.
    Dim col As Long
    ' Variable: colCount stores the column index or color-related value.
    Dim colCount As Long
    ' Variable: itemSize stores the working value for item size.
    Dim itemSize As Long
    ' Variable: opCount stores the count used to size or iterate the current data set.
    Dim opCount As Long
    ' Variable: opCode stores the working value for op code.
    Dim opCode As Long
    ' Variable: runCount stores the count used to size or iterate the current data set.
    Dim runCount As Long
    ' Variable: opListOfs stores the working value for op list ofs.
    Dim opListOfs As _Unsigned _Integer64
    ' Variable: dataListOfs stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataListOfs As _Unsigned _Integer64
    ' Variable: planeBase stores the working value for plane base.
    Dim planeBase As Long
    ' Variable: planeEnd stores the working value for plane end.
    Dim planeEnd As Long
    ' Variable: dstOfs stores the working value for dst ofs.
    Dim dstOfs As Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: j stores the secondary loop index.
    Dim j As Long
    ' Variable: b stores the color component or packed color helper used during image conversion.
    Dim b As _Unsigned _Byte
    ' Array: valueBytes stores the working value for value bytes.
    Dim valueBytes(3) As _Unsigned _Byte
    ' Variable: bufOfs stores the working value for buf ofs.
    Dim bufOfs As _Unsigned _Integer64
    ' Variable: dltaEnd stores the working value for dlta end.
    Dim dltaEnd As _Unsigned _Integer64

    dltaEnd = dltaOfs + dltaSize
    bufOfs = dltaOfs

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 7
        opPtrTable(i) = 0
    Next i

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 7
        dataPtrTable(i) = 0
    Next i

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 7
        Call AmgAnimReadU32BE(bufOfs, opPtrTable(i))
    Next i

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 7
        Call AmgAnimReadU32BE(bufOfs, dataPtrTable(i))
    Next i

    If (anhdBits And 1) <> 0 Then
        itemSize = 4
    Else
        itemSize = 2
    End If

    If itemSize <= 0 Then Exit Sub
    If (anim.rowBytes Mod itemSize) <> 0 Then
'         Print "DLTA op7 item size does not divide row bytes."
        Exit Sub
    End If

    colCount = anim.rowBytes \ itemSize

    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For p = 0 To anim.nPlanes - 1
        If opPtrTable(p) <> 0 Then
            If dataPtrTable(p) = 0 Then
'                 Print "DLTA op7 data pointer missing."
                Exit Sub
            End If

            opListOfs = dltaOfs + opPtrTable(p)
            dataListOfs = dltaOfs + dataPtrTable(p)

            If opListOfs >= dltaEnd Then
'                 Print "DLTA op7 opcode pointer outside chunk."
                Exit Sub
            End If

            If dataListOfs >= dltaEnd Then
'                 Print "DLTA op7 data pointer outside chunk."
                Exit Sub
            End If

            planeBase = p * anim.planeSize
            planeEnd = planeBase + anim.planeSize
            bufOfs = opListOfs

            ' Loop purpose: iterate through image columns, pixels, or horizontal positions.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For col = 0 To colCount - 1
                If bufOfs >= dltaEnd Then
'                     Print "DLTA op7 opcode list ends too early."
                    Exit Sub
                End If

                Call AmgAnimReadByte(bufOfs, b)
                opCount = b
                dstOfs = planeBase + col * itemSize

                ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For i = 1 To opCount
                    If bufOfs >= dltaEnd Then
'                         Print "DLTA op7 opcode stream ends too early."
                        Exit Sub
                    End If

                    Call AmgAnimReadByte(bufOfs, b)
                    opCode = b

                    If opCode = 0 Then
                        If bufOfs >= dltaEnd Then
'                             Print "DLTA op7 SAME count missing."
                            Exit Sub
                        End If

                        Call AmgAnimReadByte(bufOfs, b)
                        runCount = b

                        If dataListOfs + itemSize > dltaEnd Then
'                             Print "DLTA op7 SAME data overruns chunk."
                            Exit Sub
                        End If

                        ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
                        ' The loop order matters because later statements expect the data to be visited sequentially.
                        For j = 0 To itemSize - 1
                            valueBytes(j) = AmgAnimGetActiveByte(dataListOfs + j)
                        Next j
                        dataListOfs = dataListOfs + itemSize

                        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
                        Do While runCount > 0
                            If dstOfs < planeBase Or dstOfs + itemSize > planeEnd Then
'                                 Print "DLTA op7 SAME overruns plane."
                                Exit Sub
                            End If

                            ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
                            ' The loop order matters because later statements expect the data to be visited sequentially.
                            For j = 0 To itemSize - 1
                                planar(dstOfs + j) = valueBytes(j)
                            Next j

                            dstOfs = dstOfs + anim.rowBytes
                            runCount = runCount - 1
                        Loop

                    ElseIf (opCode And &H80) <> 0 Then
                        runCount = opCode And &H7F

                        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
                        Do While runCount > 0
                            If dataListOfs + itemSize > dltaEnd Then
'                                 Print "DLTA op7 UNIQ data overruns chunk."
                                Exit Sub
                            End If

                            If dstOfs < planeBase Or dstOfs + itemSize > planeEnd Then
'                                 Print "DLTA op7 UNIQ overruns plane."
                                Exit Sub
                            End If

                            ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
                            ' The loop order matters because later statements expect the data to be visited sequentially.
                            For j = 0 To itemSize - 1
                                planar(dstOfs + j) = AmgAnimGetActiveByte(dataListOfs + j)
                            Next j

                            dataListOfs = dataListOfs + itemSize
                            dstOfs = dstOfs + anim.rowBytes
                            runCount = runCount - 1
                        Loop

                    Else
                        dstOfs = dstOfs + opCode * anim.rowBytes

                        If dstOfs < planeBase Or dstOfs > planeEnd Then
'                             Print "DLTA op7 SKIP overruns plane column."
                            Exit Sub
                        End If
                    End If
                Next i
            Next col
        End If
    Next p
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy planar buffer.
' Parameters: src = source-side value or buffer reference; dst = destination-side value or buffer reference.
Sub AmgAnimCopyPlanarBuffer (src() As _Unsigned _Byte, dst() As _Unsigned _Byte)
    ' Variable: dstMem stores the memory handle or memory-related helper value.
    Dim dstMem As _MEM

    If UBound(src) <> UBound(dst) Then Exit Sub
    dstMem = _Mem(dst())
    _MemPut dstMem, dstMem.OFFSET, src()
    If _MemExists(dstMem) Then _MemFree dstMem
End Sub


' Purpose: Convert decoded Amiga bitmap state into a QB64 image.
' Parameters: targetImg = QB64 image handle used to store or draw decoded pixels; anim = working value for animation; pal = working value for pal; chunky = working value for chunky.
Sub AmgAnimRenderChunkyFrameMem (targetImg As Long, anim As AmgAnimInfo, pal() As AmgAnimRGB8, chunky() As _Unsigned _Byte)
    ' Variable: x stores the horizontal pixel or coordinate index.
    Dim x As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: idx stores the working value for idx.
    Dim idx As Long
    ' Variable: rr stores the working value for rr.
    Dim rr As Long
    ' Variable: gg stores the working value for gg.
    Dim gg As Long
    ' Variable: bb stores the working value for bb.
    Dim bb As Long
    ' Variable: ctrl stores the working value for ctrl.
    Dim ctrl As Long
    ' Variable: dataValue stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataValue As Long
    ' Variable: hamDataBits stores the buffer that holds raw, packed, or decoded byte data.
    Dim hamDataBits As Long
    ' Variable: hamDataMask stores the buffer that holds raw, packed, or decoded byte data.
    Dim hamDataMask As Long
    ' Variable: rowOfs stores the row pointer, row buffer, or row index used for image processing.
    Dim rowOfs As Long
    ' Variable: pixelIndex stores the index variable used to address the current item.
    Dim pixelIndex As Long
    ' Variable: frameMem stores the memory handle or memory-related helper value.
    Dim frameMem As _MEM
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Array: pal32 stores the working value for pal 32.
    Dim pal32(255) As _Unsigned Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long

    If targetImg > -2 Then Exit Sub
    pixelCount = anim.w * anim.h
    If pixelCount <= 0 Then Exit Sub
    If pixelCount <> amg_anim_scratch_pixels_size Then
        ' dynamic array: amg_anim_scratch_pixels is resized here to hold the working value for Amiga animation scratch pixels.
        ReDim amg_anim_scratch_pixels(pixelCount - 1) As _Unsigned Long
        amg_anim_scratch_pixels_size = pixelCount
    End If

    If anim.isHAM Then
        hamDataBits = anim.nPlanes - 2
        If hamDataBits < 1 Then hamDataBits = 1
        hamDataMask = 2 ^ hamDataBits - 1

        ' Loop purpose: iterate through image rows or vertical positions.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For y = 0 To anim.h - 1
            rowOfs = y * anim.w
            rr = 0
            gg = 0
            bb = 0

            ' Loop purpose: iterate through image columns, pixels, or horizontal positions.
            ' The loop order matters because later statements expect the data to be visited sequentially.
            For x = 0 To anim.w - 1
                idx = chunky(rowOfs + x)
                ctrl = idx \ (2 ^ hamDataBits)
                dataValue = idx And hamDataMask

                Select Case ctrl
                    Case 0
                        If dataValue >= 0 And dataValue <= UBound(pal) Then
                            rr = pal(dataValue).r
                            gg = pal(dataValue).g
                            bb = pal(dataValue).b
                        Else
                            rr = 255
                            gg = 0
                            bb = 255
                        End If
                    Case 1
                        If hamDataBits = 6 Then
                            bb = (dataValue * 4) Or (bb And 3)
                        ElseIf hamDataBits = 4 Then
                            bb = dataValue * 17
                        Else
                            bb = (dataValue * 255) \ hamDataMask
                        End If
                    Case 2
                        If hamDataBits = 6 Then
                            rr = (dataValue * 4) Or (rr And 3)
                        ElseIf hamDataBits = 4 Then
                            rr = dataValue * 17
                        Else
                            rr = (dataValue * 255) \ hamDataMask
                        End If
                    Case 3
                        If hamDataBits = 6 Then
                            gg = (dataValue * 4) Or (gg And 3)
                        ElseIf hamDataBits = 4 Then
                            gg = dataValue * 17
                        Else
                            gg = (dataValue * 255) \ hamDataMask
                        End If
                End Select

                pixelIndex = rowOfs + x
                amg_anim_scratch_pixels(pixelIndex) = _RGB32(rr, gg, bb)
            Next x
        Next y
    Else
        ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For i = 0 To 255
            If i <= UBound(pal) Then
                pal32(i) = _RGB32(pal(i).r, pal(i).g, pal(i).b)
            Else
                pal32(i) = _RGB32(255, 0, 255)
            End If
        Next i

        ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For i = 0 To pixelCount - 1
            amg_anim_scratch_pixels(i) = pal32(chunky(i))
        Next i
    End If

    frameMem = _MemImage(targetImg)
    _MemPut frameMem, frameMem.OFFSET, amg_anim_scratch_pixels()
    If _MemExists(frameMem) Then _MemFree frameMem
End Sub


' Purpose: Convert decoded Amiga bitmap state into a QB64 image.
' Parameters: targetImg = QB64 image handle used to store or draw decoded pixels; anim = working value for animation; pal = working value for pal; planar = working value for planar.
Sub AmgAnimRenderPlanarFrameMem (targetImg As Long, anim As AmgAnimInfo, pal() As AmgAnimRGB8, planar() As _Unsigned _Byte)
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: xByte stores the working value for x byte.
    Dim xByte As Long
    ' Variable: p stores the generic pointer or position value.
    Dim p As Long
    ' Variable: rowBase stores the row pointer, row buffer, or row index used for image processing.
    Dim rowBase As Long
    ' Array: planeBase stores the working value for plane base.
    Dim planeBase(7) As Long
    ' Array: pb stores the working value for pb.
    Dim pb(7) As _Unsigned _Byte
    ' Variable: c0 stores the working value for c 0.
    Dim c0 As Long
    ' Variable: c1 stores the working value for c 1.
    Dim c1 As Long
    ' Variable: c2 stores the working value for c 2.
    Dim c2 As Long
    ' Variable: c3 stores the working value for c 3.
    Dim c3 As Long
    ' Variable: c4 stores the working value for c 4.
    Dim c4 As Long
    ' Variable: c5 stores the working value for c 5.
    Dim c5 As Long
    ' Variable: c6 stores the working value for c 6.
    Dim c6 As Long
    ' Variable: c7 stores the working value for c 7.
    Dim c7 As Long
    ' Variable: bitValue stores the working value for bit value.
    Dim bitValue As Long
    ' Variable: baseX stores the working value for base x.
    Dim baseX As Long
    ' Variable: rowPixelBase stores the row pointer, row buffer, or row index used for image processing.
    Dim rowPixelBase As Long
    ' Variable: rowPixelLimit stores the row pointer, row buffer, or row index used for image processing.
    Dim rowPixelLimit As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: frameMem stores the memory handle or memory-related helper value.
    Dim frameMem As _MEM
    ' Array: pal32 stores the working value for pal 32.
    Dim pal32(255) As _Unsigned Long
    ' Variable: i stores the general-purpose loop index.
    Dim i As Long
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Unsigned _Byte
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Unsigned _Byte
    ' Variable: b2 stores the working value for b 2.
    Dim b2 As _Unsigned _Byte
    ' Variable: b3 stores the working value for b 3.
    Dim b3 As _Unsigned _Byte
    ' Variable: b4 stores the working value for b 4.
    Dim b4 As _Unsigned _Byte
    ' Variable: b5 stores the working value for b 5.
    Dim b5 As _Unsigned _Byte
    ' Variable: b6 stores the working value for b 6.
    Dim b6 As _Unsigned _Byte
    ' Variable: b7 stores the working value for b 7.
    Dim b7 As _Unsigned _Byte

    If targetImg > -2 Then Exit Sub
    If anim.isHAM Then
        Call AmgAnimPlanarToChunky(anim, planar(), amg_anim_scratch_chunky())
        Call AmgAnimRenderChunkyFrameMem(targetImg, anim, pal(), amg_anim_scratch_chunky())
        Exit Sub
    End If

    pixelCount = anim.w * anim.h
    If pixelCount <= 0 Then Exit Sub
    If pixelCount <> amg_anim_scratch_pixels_size Then
        ' dynamic array: amg_anim_scratch_pixels is resized here to hold the working value for Amiga animation scratch pixels.
        ReDim amg_anim_scratch_pixels(pixelCount - 1) As _Unsigned Long
        amg_anim_scratch_pixels_size = pixelCount
    End If

    If anim.nPlanes <= 0 Then Exit Sub
    If anim.nPlanes > 8 Then
        Call AmgAnimPlanarToChunky(anim, planar(), amg_anim_scratch_chunky())
        Call AmgAnimRenderChunkyFrameMem(targetImg, anim, pal(), amg_anim_scratch_chunky())
        Exit Sub
    End If

    ' Loop purpose: use i as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For i = 0 To 255
        If i <= UBound(pal) Then
            pal32(i) = _RGB32(pal(i).r, pal(i).g, pal(i).b)
        Else
            pal32(i) = _RGB32(255, 0, 255)
        End If
    Next i

    ' Loop purpose: use p as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For p = 0 To anim.nPlanes - 1
        planeBase(p) = p * anim.planeSize
    Next p

    ' Loop purpose: iterate through image rows or vertical positions.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For y = 0 To anim.h - 1
        rowBase = y * anim.rowBytes
        rowPixelBase = y * anim.w
        rowPixelLimit = rowPixelBase + anim.w

        ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For xByte = 0 To anim.rowBytes - 1
            baseX = rowPixelBase + xByte * 8
            If baseX >= rowPixelLimit Then Exit For

            c0 = 0: c1 = 0: c2 = 0: c3 = 0
            c4 = 0: c5 = 0: c6 = 0: c7 = 0

            Select Case anim.nPlanes
                Case 1
                b0 = planar(planeBase(0) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0

                Case 2
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b1 And 128) <> 0 Then c0 = c0 Or 2
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b1 And 16) <> 0 Then c3 = c3 Or 2
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2

                Case 3
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)
                b2 = planar(planeBase(2) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
                If (b1 And 128) <> 0 Then c0 = c0 Or 2
                If (b2 And 128) <> 0 Then c0 = c0 Or 4
                If (b0 And 64) <> 0 Then c1 = 1 Else c1 = 0
                If (b1 And 64) <> 0 Then c1 = c1 Or 2
                If (b2 And 64) <> 0 Then c1 = c1 Or 4
                If (b0 And 32) <> 0 Then c2 = 1 Else c2 = 0
                If (b1 And 32) <> 0 Then c2 = c2 Or 2
                If (b2 And 32) <> 0 Then c2 = c2 Or 4
                If (b0 And 16) <> 0 Then c3 = 1 Else c3 = 0
                If (b1 And 16) <> 0 Then c3 = c3 Or 2
                If (b2 And 16) <> 0 Then c3 = c3 Or 4
                If (b0 And 8) <> 0 Then c4 = 1 Else c4 = 0
                If (b1 And 8) <> 0 Then c4 = c4 Or 2
                If (b2 And 8) <> 0 Then c4 = c4 Or 4
                If (b0 And 4) <> 0 Then c5 = 1 Else c5 = 0
                If (b1 And 4) <> 0 Then c5 = c5 Or 2
                If (b2 And 4) <> 0 Then c5 = c5 Or 4
                If (b0 And 2) <> 0 Then c6 = 1 Else c6 = 0
                If (b1 And 2) <> 0 Then c6 = c6 Or 2
                If (b2 And 2) <> 0 Then c6 = c6 Or 4
                If (b0 And 1) <> 0 Then c7 = 1 Else c7 = 0
                If (b1 And 1) <> 0 Then c7 = c7 Or 2
                If (b2 And 1) <> 0 Then c7 = c7 Or 4

                Case 4
                b0 = planar(planeBase(0) + rowBase + xByte)
                b1 = planar(planeBase(1) + rowBase + xByte)
                b2 = planar(planeBase(2) + rowBase + xByte)
                b3 = planar(planeBase(3) + rowBase + xByte)

                If (b0 And 128) <> 0 Then c0 = 1 Else c0 = 0
