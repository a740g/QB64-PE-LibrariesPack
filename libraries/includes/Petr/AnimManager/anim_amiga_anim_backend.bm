' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation get frame info.
' Parameters: animId = working value for animation id; frameIndex = index variable used to address the current item; frameInfo = working value for frame info.
Sub AmgAnimGetFrameInfo (animId As Long, frameIndex As Long, frameInfo As AmgAnimFrameInfo)
    frameInfo = AmgAnimFrames(AmgAnimItems(animId).FrameStart + frameIndex)
End Sub


' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy local palette to scratch.
' Parameters: pal = working value for pal.
Sub AmgAnimCopyLocalPaletteToScratch (pal() As AmgAnimRGB8)
    ' Variable: colorCount stores the column index or color-related value.
    Dim colorCount As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    colorCount = UBound(pal) + 1
    If colorCount <= 0 Then colorCount = 1

    If colorCount > amg_anim_scratch_pal_size Then
        ' dynamic array: amg_anim_scratch_pal is resized here to hold the working value for Amiga animation scratch pal.
        ReDim amg_anim_scratch_pal(colorCount - 1) As AmgAnimRGB8
        amg_anim_scratch_pal_size = colorCount
    End If

    ' Loop purpose: use indexValue as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To colorCount - 1
        amg_anim_scratch_pal(indexValue) = pal(indexValue)
    Next indexValue
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation copy scratch palette to local.
' Parameters: colorCount = column index or color-related value; pal = working value for pal.
Sub AmgAnimCopyScratchPaletteToLocal (colorCount As Long, pal() As AmgAnimRGB8)
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    If colorCount <= 0 Then colorCount = 1
    ' dynamic array: pal is resized here to hold the working value for pal.
    ReDim pal(colorCount - 1) As AmgAnimRGB8

    ' Loop purpose: use indexValue as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To colorCount - 1
        pal(indexValue) = amg_anim_scratch_pal(indexValue)
    Next indexValue
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation flush scratch owner.
Sub AmgAnimFlushScratchOwner ()
    ' Variable: ownerId stores the working value for owner id.
    Dim ownerId As Long
    ' Variable: totalPlanar stores the working value for total planar.
    Dim totalPlanar As Long
    ' Variable: totalChunky stores the working value for total chunky.
    Dim totalChunky As Long

    If amg_anim_scratch_owner_valid = 0 Then Exit Sub
    ownerId = amg_anim_scratch_owner
    If AmgAnimValidId(ownerId) = 0 Then
        amg_anim_scratch_owner_valid = 0
        Exit Sub
    End If
    If AmgAnimItems(ownerId).WorkReady = 0 Then Exit Sub

    totalPlanar = AmgAnimItems(ownerId).RowBytes * AmgAnimItems(ownerId).HeightPx * AmgAnimItems(ownerId).NPlanes
    totalChunky = AmgAnimItems(ownerId).WidthPx * AmgAnimItems(ownerId).HeightPx
    Call AmgAnimCopyLocalPlanarToPool(amg_anim_scratch_planar_base(), AmgAnimItems(ownerId).WorkBaseStart, totalPlanar)
    Call AmgAnimCopyLocalPlanarToPool(amg_anim_scratch_planar_a(), AmgAnimItems(ownerId).WorkAStart, totalPlanar)
    Call AmgAnimCopyLocalPlanarToPool(amg_anim_scratch_planar_b(), AmgAnimItems(ownerId).WorkBStart, totalPlanar)
    Call AmgAnimCopyLocalPaletteToPool(amg_anim_scratch_pal(), AmgAnimItems(ownerId).PalStart, AmgAnimItems(ownerId).PalCount)
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation restore work to scratch.
' Parameters: animId = working value for animation id; anim = working value for animation; pal = working value for pal.
Sub AmgAnimRestoreWorkToScratch (animId As Long, anim As AmgAnimInfo, pal() As AmgAnimRGB8)
    ' Variable: totalPlanar stores the working value for total planar.
    Dim totalPlanar As Long
    ' Variable: totalChunky stores the working value for total chunky.
    Dim totalChunky As Long

    totalPlanar = anim.rowBytes * anim.h * anim.nPlanes
    totalChunky = anim.w * anim.h
    Call AmgAnimEnsureScratchCapacity(totalPlanar, totalChunky, AmgAnimItems(animId).PalCount)

    If amg_anim_scratch_owner_valid Then
        If amg_anim_scratch_owner = animId Then
            Call AmgAnimCopyScratchPaletteToLocal(AmgAnimItems(animId).PalCount, pal())
            Exit Sub
        End If

        Call AmgAnimFlushScratchOwner
    End If

    Call AmgAnimCopyPoolPlanarToLocal(AmgAnimItems(animId).WorkBaseStart, totalPlanar, amg_anim_scratch_planar_base())
    Call AmgAnimCopyPoolPlanarToLocal(AmgAnimItems(animId).WorkAStart, totalPlanar, amg_anim_scratch_planar_a())
    Call AmgAnimCopyPoolPlanarToLocal(AmgAnimItems(animId).WorkBStart, totalPlanar, amg_anim_scratch_planar_b())
    Call AmgAnimCopyPoolPaletteToLocal(AmgAnimItems(animId).PalStart, AmgAnimItems(animId).PalCount, pal())
    Call AmgAnimCopyLocalPaletteToScratch(pal())
    amg_anim_scratch_owner = animId
    amg_anim_scratch_owner_valid = -1
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation save scratch work.
' Parameters: animId = working value for animation id; pal = working value for pal; totalPlanar = working value for total planar; totalChunky = working value for total chunky.
Sub AmgAnimSaveScratchWork (animId As Long, pal() As AmgAnimRGB8, totalPlanar As Long, totalChunky As Long)
    Call AmgAnimCopyLocalPaletteToScratch(pal())
    amg_anim_scratch_owner = animId
    amg_anim_scratch_owner_valid = -1
End Sub

' Purpose: Routine for the Amiga ANIM backend: handle Amiga animation prepare base state.
' Parameters: animId = working value for animation id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimPrepareBaseState% (animId As Long)
    ' Variable: anim stores the working value for animation.
    Dim anim As AmgAnimInfo
    ' dynamic array: pal is resized here to hold the working value for pal.
    ReDim pal(0) As AmgAnimRGB8
    ' Variable: totalPlanar stores the working value for total planar.
    Dim totalPlanar As Long
    ' Variable: totalChunky stores the working value for total chunky.
    Dim totalChunky As Long
    ' Variable: frame0 stores the working value for frame 0.
    Dim frame0 As AmgAnimFrameInfo

    AmgAnimPrepareBaseState = 0
    If AmgAnimValidId(animId) = 0 Then Exit Function

    Call AmgAnimGetStoredInfo(animId, anim)
    totalPlanar = anim.rowBytes * anim.h * anim.nPlanes
    totalChunky = anim.w * anim.h
    Call AmgAnimEnsureScratchCapacity(totalPlanar, totalChunky, AmgAnimItems(animId).PalCount)
    Call AmgAnimFlushScratchOwner
    Call AmgAnimCopyPoolPaletteToLocal(AmgAnimItems(animId).PalStart, AmgAnimItems(animId).PalCount, pal())
    Call AmgAnimGetFrameInfo(animId, 0, frame0)

    Call AmgAnimUseSlotBuffer(animId)
    Call AmgAnimLoadFirstFramePlanar(anim, frame0, amg_anim_scratch_planar_base(), amg_anim_scratch_planar_a(), pal())
    Call AmgAnimCopyPlanarBuffer(amg_anim_scratch_planar_base(), amg_anim_scratch_planar_b())
    Call AmgAnimRenderPlanarFrameMem(AmgAnimItems(animId).CanvasImage, anim, pal(), amg_anim_scratch_planar_a())
    Call AmgAnimSaveScratchWork(animId, pal(), totalPlanar, totalChunky)

    AmgAnimItems(animId).DecodedFrame = 0
    AmgAnimItems(animId).ShownIsA = -1
    AmgAnimItems(animId).WorkReady = -1
    Call AmgAnimMaybeStoreSnapshot(animId, 0)
    AmgAnimPrepareBaseState = -1
End Function

' Purpose: Convert decoded Amiga bitmap state into a QB64 image.
' Parameters: animId = working value for animation id; frameNumber = working value for frame number.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function AmgAnimRenderFrameToCanvas% (animId As Long, frameNumber As Long)
    ' Variable: anim stores the working value for animation.
    Dim anim As AmgAnimInfo
    ' dynamic array: pal is resized here to hold the working value for pal.
    ReDim pal(0) As AmgAnimRGB8
    ' Variable: totalPlanar stores the working value for total planar.
    Dim totalPlanar As Long
    ' Variable: totalChunky stores the working value for total chunky.
    Dim totalChunky As Long
    ' Variable: frameIndex stores the index variable used to address the current item.
    Dim frameIndex As Long
    ' Variable: usePrev stores the working value for use prev.
    Dim usePrev As Long
    ' Variable: frame0 stores the working value for frame 0.
    Dim frame0 As AmgAnimFrameInfo
    ' Variable: curFrame stores the working value for cur frame.
    Dim curFrame As AmgAnimFrameInfo
    ' Variable: restoredFrame stores the working value for restored frame.
    Dim restoredFrame As Long

    AmgAnimRenderFrameToCanvas = 0
    If AmgAnimValidId(animId) = 0 Then Exit Function
    If frameNumber < 0 Then Exit Function
    If frameNumber >= AmgAnimItems(animId).FrameCount Then Exit Function
    If AmgAnimItems(animId).CanvasImage > -2 Then Exit Function

    Call AmgAnimGetStoredInfo(animId, anim)
    totalPlanar = anim.rowBytes * anim.h * anim.nPlanes
    totalChunky = anim.w * anim.h
    Call AmgAnimEnsureScratchCapacity(totalPlanar, totalChunky, AmgAnimItems(animId).PalCount)

    If AmgAnimItems(animId).WorkReady = 0 Then
        If AmgAnimPrepareBaseState(animId) = 0 Then Exit Function
        If frameNumber = 0 Then
            AmgAnimItems(animId).RenderedFrame = 0
            AmgAnimRenderFrameToCanvas = -1
            Exit Function
        End If
    End If

    Call AmgAnimRestoreWorkToScratch(animId, anim, pal())
    Call AmgAnimUseSlotBuffer(animId)

    If frameNumber = 0 Then
        Call AmgAnimGetFrameInfo(animId, 0, frame0)
        Call AmgAnimLoadFirstFramePlanar(anim, frame0, amg_anim_scratch_planar_base(), amg_anim_scratch_planar_a(), pal())
        Call AmgAnimCopyPlanarBuffer(amg_anim_scratch_planar_base(), amg_anim_scratch_planar_b())
        Call AmgAnimRenderPlanarFrameMem(AmgAnimItems(animId).CanvasImage, anim, pal(), amg_anim_scratch_planar_a())
        Call AmgAnimSaveScratchWork(animId, pal(), totalPlanar, totalChunky)
        AmgAnimItems(animId).DecodedFrame = 0
        AmgAnimItems(animId).ShownIsA = -1
        AmgAnimItems(animId).RenderedFrame = 0
        AmgAnimItems(animId).WorkReady = -1
        Call AmgAnimMaybeStoreSnapshot(animId, 0)
        AmgAnimRenderFrameToCanvas = -1
        Exit Function
    End If

    If frameNumber < AmgAnimItems(animId).DecodedFrame Then
        restoredFrame = -1
        If AmgAnimRestoreNearestSnapshot(animId, frameNumber, anim, pal(), restoredFrame) = 0 Then
            Call AmgAnimGetFrameInfo(animId, 0, frame0)
            Call AmgAnimLoadFirstFramePlanar(anim, frame0, amg_anim_scratch_planar_base(), amg_anim_scratch_planar_a(), pal())
            Call AmgAnimCopyPlanarBuffer(amg_anim_scratch_planar_base(), amg_anim_scratch_planar_b())
            AmgAnimItems(animId).DecodedFrame = 0
            AmgAnimItems(animId).ShownIsA = -1
        End If
    End If

    If frameNumber > AmgAnimItems(animId).DecodedFrame Then
        frameIndex = AmgAnimItems(animId).DecodedFrame + 1
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While frameIndex <= frameNumber
            usePrev = 0
            Call AmgAnimGetFrameInfo(animId, frameIndex, curFrame)
            If curFrame.interleave = 1 Then usePrev = -1

            If AmgAnimItems(animId).ShownIsA Then
                If usePrev Then Call AmgAnimCopyPlanarBuffer(amg_anim_scratch_planar_a(), amg_anim_scratch_planar_b())
                Call AmgAnimDecodeFrameToHidden(anim, curFrame, amg_anim_scratch_planar_a(), amg_anim_scratch_planar_b(), pal())
                AmgAnimItems(animId).ShownIsA = 0
            Else
                If usePrev Then Call AmgAnimCopyPlanarBuffer(amg_anim_scratch_planar_b(), amg_anim_scratch_planar_a())
                Call AmgAnimDecodeFrameToHidden(anim, curFrame, amg_anim_scratch_planar_b(), amg_anim_scratch_planar_a(), pal())
                AmgAnimItems(animId).ShownIsA = -1
            End If

            Call AmgAnimMaybeStoreSnapshot(animId, frameIndex)
            frameIndex = frameIndex + 1
        Loop
    End If

    If AmgAnimItems(animId).ShownIsA Then
        Call AmgAnimRenderPlanarFrameMem(AmgAnimItems(animId).CanvasImage, anim, pal(), amg_anim_scratch_planar_a())
    Else
        Call AmgAnimRenderPlanarFrameMem(AmgAnimItems(animId).CanvasImage, anim, pal(), amg_anim_scratch_planar_b())
    End If

    Call AmgAnimSaveScratchWork(animId, pal(), totalPlanar, totalChunky)
    AmgAnimItems(animId).DecodedFrame = frameNumber
    AmgAnimItems(animId).RenderedFrame = frameNumber
    AmgAnimItems(animId).WorkReady = -1
    Call AmgAnimMaybeStoreSnapshot(animId, frameNumber)
    AmgAnimRenderFrameToCanvas = -1
End Function


