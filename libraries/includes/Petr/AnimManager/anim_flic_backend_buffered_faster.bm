$INCLUDEONCE

$IF VERSION < 4.3.0 THEN
    $ERROR "The Libraries Pack add-on needs at least QB64-PE v4.3.0"
$END IF

' =========================================================
' Commented source copy for the FLIC/FLC backend.
' Explanatory comments were added in English without altering executable code.
' =========================================================
' Purpose: Open an Autodesk FLI/FLC file, parse headers, and prepare buffered playback.
' Parameters: fileName = string holding a file path or a human-readable name; maxWidth = maximum allowed width; maxHeight = maximum allowed height; maxFrames = maximum allowed frames.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicOpenLimit& (fileName As String, maxWidth As Long, maxHeight As Long, maxFrames As Long)
    ' Variable: formatId stores the numeric identifier of the detected animation file format.
    Dim formatId As Long
    ' Variable: fileNum stores the working value for file num.
    Dim fileNum As Integer
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: headerData stores the buffer that holds raw, packed, or decoded byte data.
    Dim headerData As FLICHeaderType
    ' Variable: imageHandle stores the QB64 image handle used to store or draw decoded pixels.
    Dim imageHandle As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: frameStart stores the working value for frame start.
    Dim frameStart As Long
    ' Variable: snapshotMetaStart stores the working value for snapshot meta start.
    Dim snapshotMetaStart As Long
    ' Variable: snapshotCount stores the count used to size or iterate the current data set.
    Dim snapshotCount As Long
    ' Variable: hasRing stores the Boolean-like flag used by the current routine.
    Dim hasRing As Integer
    ' Variable: ringOffset stores the working value for ring offset.
    Dim ringOffset As _Integer64
    ' Variable: ringSize stores the working value for ring size.
    Dim ringSize As _Integer64
    ' Variable: fileSize stores the working value for file size.
    Dim fileSize As _Integer64
    ' Variable: fileDataStart stores the buffer that holds raw, packed, or decoded byte data.
    Dim fileDataStart As Long

    FlicOpenLimit& = -1
    formatId = ANIM_FORMAT_NONE
    fileNum = 0
    slotId = -1
    imageHandle = -1
    pixelCount = 0
    pixelStart = -1
    frameStart = -1
    snapshotMetaStart = -1
    snapshotCount = 0
    hasRing = 0
    ringOffset = 0
    ringSize = 0
    fileSize = 0
    fileDataStart = -1

    If _FileExists(fileName) = 0 Then Exit Function

    fileNum = FreeFile
    Open fileName For Binary As #fileNum

    If FlicReadHeaderFromFile(fileNum, headerData, formatId) = 0 Then
        Close #fileNum
        Exit Function
    End If

    If maxWidth > 0 Then
        If headerData.Width > maxWidth Then
            Close #fileNum
            Exit Function
        End If
    End If

    If maxHeight > 0 Then
        If headerData.Height > maxHeight Then
            Close #fileNum
            Exit Function
        End If
    End If

    If maxFrames > 0 Then
        If headerData.Frames > maxFrames Then
            Close #fileNum
            Exit Function
        End If
    End If

    fileSize = LOF(fileNum)
    If fileSize < 128 Then
        Close #fileNum
        Exit Function
    End If

    slotId = FlicAllocSlot
    If slotId < 0 Then
        Close #fileNum
        Exit Function
    End If

    FlicInitSlot slotId
    FlicFileNames(slotId) = fileName

    fileDataStart = FlicAllocFileBlock(fileSize)
    If fileDataStart < 0 Then
        Close #fileNum
        FlicSetError slotId, "FlicOpenLimit: file RAM allocation failed"
        Exit Function
    End If

    If FlicLoadWholeFileToRam(fileNum, fileDataStart, fileSize) = 0 Then
        Close #fileNum
        FlicSetError slotId, "FlicOpenLimit: file RAM load failed"
        Exit Function
    End If

    Close #fileNum

    imageHandle = FlicCreateRenderImage(headerData.Width, headerData.Height)
    If imageHandle > -2 Then
        FlicSetError slotId, "FlicOpenLimit: _NewImage failed"
        Exit Function
    End If

    pixelCount = headerData.Width * headerData.Height
    If pixelCount < 1 Then
        If imageHandle <= -2 Then _FreeImage imageHandle: imageHandle = 0
        FlicSetError slotId, "FlicOpenLimit: invalid pixel count"
        Exit Function
    End If

    pixelStart = FlicAllocPixelBlock(pixelCount)
    If pixelStart < 0 Then
        If imageHandle <= -2 Then _FreeImage imageHandle: imageHandle = 0
        FlicSetError slotId, "FlicOpenLimit: pixel buffer allocation failed"
        Exit Function
    End If

    frameStart = FlicAllocFrameBlock(headerData.Frames)
    If frameStart < 0 Then
        If imageHandle <= -2 Then _FreeImage imageHandle: imageHandle = 0
        FlicSetError slotId, "FlicOpenLimit: frame index allocation failed"
        Exit Function
    End If

    snapshotCount = FlicCountSnapshots(headerData.Frames, FLIC_SNAPSHOT_INTERVAL)
    snapshotMetaStart = FlicAllocSnapshotMetaBlock(snapshotCount, pixelCount)
    If snapshotMetaStart < 0 Then
        If imageHandle <= -2 Then _FreeImage imageHandle: imageHandle = 0
        FlicSetError slotId, "FlicOpenLimit: snapshot cache allocation failed"
        Exit Function
    End If

    If FlicBuildFrameIndex(fileDataStart, fileSize, headerData, formatId, headerData.Frames, frameStart, hasRing, ringOffset, ringSize) = 0 Then
        If imageHandle <= -2 Then _FreeImage imageHandle: imageHandle = 0
        FlicSetError slotId, "FlicOpenLimit: frame index build failed"
        Exit Function
    End If

    FlicItems(slotId).Used = -1
    FlicItems(slotId).FormatType = formatId
    FlicItems(slotId).WidthPx = headerData.Width
    FlicItems(slotId).HeightPx = headerData.Height
    FlicItems(slotId).FrameCount = headerData.Frames
    FlicItems(slotId).DefaultDelayMS = headerData.SpeedMS
    FlicItems(slotId).CurrentFrame = 0
    FlicItems(slotId).DecodedFrame = -1
    FlicItems(slotId).Playing = 0
    FlicItems(slotId).Paused = 0
    FlicItems(slotId).Looping = -1
    FlicItems(slotId).LastTick = 0
    FlicItems(slotId).NextTick = 0
    FlicItems(slotId).RemainingDelay = 0
    FlicItems(slotId).LastRawTimer = 0
    FlicItems(slotId).CanvasImage = imageHandle
    FlicItems(slotId).ImageDirty = -1
    FlicItems(slotId).PaletteDirty = -1
    FlicItems(slotId).DirtyValid = 0
    FlicItems(slotId).DirtyLeft = 0
    FlicItems(slotId).DirtyTop = 0
    FlicItems(slotId).DirtyRight = 0
    FlicItems(slotId).DirtyBottom = 0
    FlicItems(slotId).HeaderData = headerData
    FlicItems(slotId).FileDataStart = fileDataStart
    FlicItems(slotId).FileDataSize = fileSize
    FlicItems(slotId).PixelStart = pixelStart
    FlicItems(slotId).PixelCount = pixelCount
    FlicItems(slotId).FrameInfoStart = frameStart
    FlicItems(slotId).HasRingFrame = hasRing
    FlicItems(slotId).RingFrameOffset64 = ringOffset
    FlicItems(slotId).RingFrameSize64 = ringSize
    FlicItems(slotId).SnapshotMetaStart = snapshotMetaStart
    FlicItems(slotId).SnapshotCount = snapshotCount
    FlicItems(slotId).SnapshotInterval = FLIC_SNAPSHOT_INTERVAL
    FlicSetError slotId, ""

    FlicResetDecodeState slotId

    FlicOpenLimit& = slotId
End Function

' Purpose: Read FLI/FLC metadata without fully opening the animation.
' Parameters: fileName = string holding a file path or a human-readable name; ok = success flag returned by the current routine; formatId = numeric identifier of the detected animation file format; widthPx = decoded image width in pixels; heightPx = decoded image height in pixels; frameCount = total number of frames available for the current animation.
Sub FlicProbe (fileName As String, ok As Integer, formatId As Long, widthPx As Long, heightPx As Long, frameCount As Long)
    ' Variable: fileNum stores the working value for file num.
    Dim fileNum As Integer
    ' Variable: headerData stores the buffer that holds raw, packed, or decoded byte data.
    Dim headerData As FLICHeaderType

    ok = 0
    formatId = ANIM_FORMAT_NONE
    widthPx = 0
    heightPx = 0
    frameCount = 0
    fileNum = 0

    If _FileExists(fileName) = 0 Then Exit Sub

    fileNum = FreeFile
    Open fileName For Binary As #fileNum

    If FlicReadHeaderFromFile(fileNum, headerData, formatId) Then
        ok = -1
        widthPx = headerData.Width
        heightPx = headerData.Height
        frameCount = headerData.Frames
    End If

    Close #fileNum
End Sub

' Purpose: Release all resources owned by one FLI/FLC decoder instance.
' Parameters: flicId = working value for FLIC id.
Sub FlicClose (flicId As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub

    If FlicItems(flicId).CanvasImage <= -2 Then
        _FreeImage FlicItems(flicId).CanvasImage
    End If

    If FlicDecodeContextId = flicId Then
        FlicDecodeContextId = -1
    End If

    FlicItems(flicId).CanvasImage = -1
    FlicItems(flicId).Used = 0
    FlicItems(flicId).FormatType = ANIM_FORMAT_NONE
    FlicItems(flicId).WidthPx = 0
    FlicItems(flicId).HeightPx = 0
    FlicItems(flicId).FrameCount = 0
    FlicItems(flicId).DefaultDelayMS = 0
    FlicItems(flicId).CurrentFrame = 0
    FlicItems(flicId).DecodedFrame = -1
    FlicItems(flicId).Playing = 0
    FlicItems(flicId).Paused = 0
    FlicItems(flicId).Looping = 0
    FlicItems(flicId).LastTick = 0
    FlicItems(flicId).NextTick = 0
    FlicItems(flicId).RemainingDelay = 0
    FlicItems(flicId).ImageDirty = 0
    FlicItems(flicId).PaletteDirty = 0
    FlicItems(flicId).DirtyValid = 0
    FlicItems(flicId).DirtyLeft = 0
    FlicItems(flicId).DirtyTop = 0
    FlicItems(flicId).DirtyRight = 0
    FlicItems(flicId).DirtyBottom = 0
    FlicItems(flicId).FileDataStart = 0
    FlicItems(flicId).FileDataSize = 0
    FlicItems(flicId).PixelStart = 0
    FlicItems(flicId).PixelCount = 0
    FlicItems(flicId).FrameInfoStart = 0
    FlicItems(flicId).HasRingFrame = 0
    FlicItems(flicId).RingFrameOffset64 = 0
    FlicItems(flicId).RingFrameSize64 = 0
    FlicItems(flicId).SnapshotMetaStart = 0
    FlicItems(flicId).SnapshotCount = 0
    FlicItems(flicId).SnapshotInterval = 0
    FlicFileNames(flicId) = ""
    FlicErrorTexts(flicId) = ""
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC free all.
Sub FlicFreeAll ()
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    ' Loop purpose: walk through every currently allocated element in FlicItems.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To UBound(FlicItems)
        If FlicItems(indexValue).Used Then
            FlicClose indexValue
        End If
    Next indexValue
End Sub

' Purpose: Start FLI/FLC playback timing.
' Parameters: flicId = working value for FLIC id.
Sub FlicStart (flicId As Long)
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double
    ' Variable: nowValue stores the working value for now value.
    Dim nowValue As Double

    If FlicValidId(flicId) = 0 Then Exit Sub
    If FlicItems(flicId).FrameCount < 1 Then Exit Sub

    FlicItems(flicId).CurrentFrame = 0
    FlicItems(flicId).Playing = -1
    FlicItems(flicId).Paused = 0
    FlicItems(flicId).RemainingDelay = 0

    FlicResetDecodeState flicId
    If FlicEnsureRenderedFrame(flicId, 0) = 0 Then
        FlicItems(flicId).Playing = 0
        Exit Sub
    End If

    delaySec = FlicGetFrameDelay(flicId, FlicItems(flicId).CurrentFrame) / 1000#
    If delaySec <= 0 Then delaySec = .03

    ' Start playback from a fresh absolute schedule based on the current frame.
    nowValue = Timer
    FlicItems(flicId).LastTick = nowValue
    FlicItems(flicId).LastRawTimer = nowValue
    FlicItems(flicId).NextTick = FlicTimeAdd(FlicItems(flicId).LastTick, delaySec)
End Sub

' Purpose: Stop FLI/FLC playback timing.
' Parameters: flicId = working value for FLIC id.
Sub FlicStop (flicId As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub
    FlicMakeDefaultStopState flicId
End Sub

' Purpose: Pause FLI/FLC playback while keeping the current frame.
' Parameters: flicId = working value for FLIC id.
Sub FlicPause (flicId As Long)
    ' Variable: nowValue stores the working value for now value.
    Dim nowValue As Double

    If FlicValidId(flicId) = 0 Then Exit Sub
    If FlicItems(flicId).Playing = 0 Then Exit Sub

    ' Preserve the remaining frame time so resume continues the current frame.
    nowValue = Timer
    FlicItems(flicId).RemainingDelay = FlicTimeRemaining(FlicItems(flicId).NextTick, nowValue)
    FlicItems(flicId).LastRawTimer = nowValue
    FlicItems(flicId).Paused = -1
End Sub

' Purpose: Resume FLI/FLC playback after a pause.
' Parameters: flicId = working value for FLIC id.
Sub FlicResume (flicId As Long)
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double
    ' Variable: nowValue stores the working value for now value.
    Dim nowValue As Double

    If FlicValidId(flicId) = 0 Then Exit Sub
    If FlicItems(flicId).Playing = 0 Then Exit Sub
    If FlicItems(flicId).Paused = 0 Then Exit Sub

    ' Resume from the leftover delay instead of restarting a full frame delay.
    nowValue = Timer
    delaySec = FlicItems(flicId).RemainingDelay
    If delaySec <= 0 Then
        delaySec = FlicGetFrameDelay(flicId, FlicItems(flicId).CurrentFrame) / 1000#
        If delaySec <= 0 Then delaySec = .03
    End If

    FlicItems(flicId).Paused = 0
    FlicItems(flicId).LastTick = nowValue
    FlicItems(flicId).LastRawTimer = nowValue
    FlicItems(flicId).NextTick = FlicTimeAdd(FlicItems(flicId).LastTick, delaySec)
    FlicItems(flicId).RemainingDelay = 0
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC set loop.
' Parameters: flicId = working value for FLIC id; loopMode = loop policy that controls whether playback stops or repeats.
Sub FlicSetLoop (flicId As Long, loopMode As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub

    If loopMode Then
        FlicItems(flicId).Looping = -1
    Else
        FlicItems(flicId).Looping = 0
    End If
End Sub

' Purpose: Advance FLI/FLC playback according to frame timing.
' Parameters: flicId = working value for FLIC id.
Sub FlicUpdate (flicId As Long)
    ' Variable: currentTime stores the time-related value used by the current routine.
    Dim currentTime As Double
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double
    ' Variable: nextFrame stores the working value for next frame.
    Dim nextFrame As Long
    ' Variable: stepCount stores the count used to size or iterate the current data set.
    Dim stepCount As Long
    ' Variable: jumpFlag stores the working value for jump flag.
    Dim jumpFlag As Integer

    If FlicValidId(flicId) = 0 Then Exit Sub
    If FlicItems(flicId).Playing = 0 Then Exit Sub
    If FlicItems(flicId).Paused Then Exit Sub

    currentTime = Timer

    ' Ignore manual system clock jumps but keep the normal midnight wrap working.
    jumpFlag = 0
    If FlicItems(flicId).LastRawTimer > 0 Then
        jumpFlag = FlicClockJumped(flicId, FlicItems(flicId).LastRawTimer, currentTime)
    End If
    If jumpFlag Then
        FlicResyncAfterClockJump flicId, currentTime
        Exit Sub
    End If

    FlicItems(flicId).LastRawTimer = currentTime
    If FlicTimerReached(FlicItems(flicId).NextTick, currentTime) = 0 Then Exit Sub

    If FlicItems(flicId).FrameCount < 1 Then
        FlicItems(flicId).Playing = 0
        Exit Sub
    End If

    ' Advance against the scheduled timeline so playback can catch up after lag.
    stepCount = 0
    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While FlicTimerReached(FlicItems(flicId).NextTick, currentTime)
        If FlicItems(flicId).CurrentFrame < FlicItems(flicId).FrameCount - 1 Then
            nextFrame = FlicItems(flicId).CurrentFrame + 1
            If FlicEnsureRenderedFrame(flicId, nextFrame) = 0 Then
                FlicItems(flicId).Playing = 0
                Exit Sub
            End If
        Else
            If FlicItems(flicId).Looping Then
                If FlicLoopToStart(flicId) = 0 Then
                    FlicItems(flicId).Playing = 0
                    Exit Sub
                End If
            Else
                FlicItems(flicId).Playing = 0
                Exit Sub
            End If
        End If

        delaySec = FlicGetFrameDelay(flicId, FlicItems(flicId).CurrentFrame) / 1000#
        If delaySec <= 0 Then delaySec = .03

        FlicItems(flicId).LastTick = FlicItems(flicId).NextTick
        FlicItems(flicId).NextTick = FlicTimeAdd(FlicItems(flicId).NextTick, delaySec)

        stepCount = stepCount + 1
        If stepCount >= 32 Then Exit Do
    Loop
End Sub

' Purpose: Draw the current FLI/FLC frame to the active QB64 target.
' Parameters: flicId = working value for FLIC id; x = horizontal pixel or coordinate index; y = vertical pixel or coordinate index.
Sub FlicDraw (flicId As Long, x As Long, y As Long)
    ' Variable: imageHandle stores the QB64 image handle used to store or draw decoded pixels.
    Dim imageHandle As Long

    imageHandle = FlicRenderCurrentImage(flicId)
    If imageHandle <= -2 Then
        _PutImage (x, y), imageHandle, 0
    End If
End Sub

' Purpose: Draw the current FLI/FLC frame to the active QB64 target.
' Parameters: flicId = working value for FLIC id; x = horizontal pixel or coordinate index; y = vertical pixel or coordinate index; boxWidth = width value used by this routine; boxHeight = height value used by this routine.
Sub FlicDrawFit (flicId As Long, x As Long, y As Long, boxWidth As Long, boxHeight As Long)
    ' Variable: imageHandle stores the QB64 image handle used to store or draw decoded pixels.
    Dim imageHandle As Long
    ' Variable: srcWidth stores the width value used by this routine.
    Dim srcWidth As Long
    ' Variable: srcHeight stores the height value used by this routine.
    Dim srcHeight As Long
    ' Variable: scaleX stores the working value for scale x.
    Dim scaleX As Single
    ' Variable: scaleY stores the working value for scale y.
    Dim scaleY As Single
    ' Variable: scaleValue stores the working value for scale value.
    Dim scaleValue As Single
    ' Variable: drawWidth stores the width value used by this routine.
    Dim drawWidth As Long
    ' Variable: drawHeight stores the height value used by this routine.
    Dim drawHeight As Long
    ' Variable: drawX stores the working value for draw x.
    Dim drawX As Long
    ' Variable: drawY stores the working value for draw y.
    Dim drawY As Long

    If boxWidth < 1 Then Exit Sub
    If boxHeight < 1 Then Exit Sub
    If FlicValidId(flicId) = 0 Then Exit Sub

    srcWidth = FlicItems(flicId).WidthPx
    srcHeight = FlicItems(flicId).HeightPx
    If srcWidth < 1 Then Exit Sub
    If srcHeight < 1 Then Exit Sub

    imageHandle = FlicRenderCurrentImage(flicId)
    If imageHandle > -2 Then Exit Sub

    scaleX = boxWidth / srcWidth
    scaleY = boxHeight / srcHeight
    If scaleX < scaleY Then
        scaleValue = scaleX
    Else
        scaleValue = scaleY
    End If
    If scaleValue <= 0 Then Exit Sub

    drawWidth = _Round(srcWidth * scaleValue)
    drawHeight = _Round(srcHeight * scaleValue)
    If drawWidth < 1 Then drawWidth = 1
    If drawHeight < 1 Then drawHeight = 1

    drawX = x + (boxWidth - drawWidth) \ 2
    drawY = y + (boxHeight - drawHeight) \ 2

    _PutImage (drawX, drawY)-(drawX + drawWidth - 1, drawY + drawHeight - 1), imageHandle, 0
End Sub

' Purpose: Draw the current FLI/FLC frame to the active QB64 target.
' Parameters: flicId = working value for FLIC id; x = horizontal pixel or coordinate index; y = vertical pixel or coordinate index; boxWidth = width value used by this routine; boxHeight = height value used by this routine.
Sub FlicDrawStretch (flicId As Long, x As Long, y As Long, boxWidth As Long, boxHeight As Long)
    ' Variable: imageHandle stores the QB64 image handle used to store or draw decoded pixels.
    Dim imageHandle As Long

    If boxWidth < 1 Then Exit Sub
    If boxHeight < 1 Then Exit Sub

    imageHandle = FlicRenderCurrentImage(flicId)
    If imageHandle <= -2 Then
        _PutImage (x, y)-(x + boxWidth - 1, y + boxHeight - 1), imageHandle, 0
    End If
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC frame count.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicFrameCount& (flicId As Long)
    FlicFrameCount& = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicFrameCount& = FlicItems(flicId).FrameCount
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC width.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicWidth& (flicId As Long)
    FlicWidth& = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicWidth& = FlicItems(flicId).WidthPx
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC height.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicHeight& (flicId As Long)
    FlicHeight& = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicHeight& = FlicItems(flicId).HeightPx
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC current frame.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicCurrentFrame& (flicId As Long)
    FlicCurrentFrame& = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicCurrentFrame& = FlicItems(flicId).CurrentFrame
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC format.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicFormat& (flicId As Long)
    FlicFormat& = ANIM_FORMAT_NONE
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicFormat& = FlicItems(flicId).FormatType
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC is playing.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicIsPlaying% (flicId As Long)
    FlicIsPlaying% = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    FlicIsPlaying% = FlicItems(flicId).Playing
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC is loaded.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicIsLoaded% (flicId As Long)
    FlicIsLoaded% = FlicValidId(flicId)
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC error.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicError$ (flicId As Long)
    FlicError$ = ""

    If flicId < 0 Then Exit Function
    If flicId > UBound(FlicErrorTexts) Then Exit Function

    FlicError$ = FlicErrorTexts(flicId)
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC get frame delay.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicGetFrameDelay& (flicId As Long, frameIndex As Long)
    FlicGetFrameDelay& = 30

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function
    ' Variable: n stores the working value for n.
    dim n as long
    FlicGetFrameDelay& = FlicItems(flicId).DefaultDelayMS
    n =  FlicItems(flicId).DefaultDelayMS
    If n < 1 Then FlicGetFrameDelay& = 30
End Function

' Purpose: Convert the current FLI/FLC frame buffer into a QB64 image.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicRenderCurrentImage& (flicId As Long)
    FlicRenderCurrentImage& = -1

    If FlicValidId(flicId) = 0 Then Exit Function
    If FlicItems(flicId).CanvasImage > -2 Then Exit Function

    If FlicItems(flicId).CurrentFrame < 0 Then
        FlicItems(flicId).CurrentFrame = 0
    End If

    If FlicItems(flicId).CurrentFrame >= FlicItems(flicId).FrameCount Then
        FlicItems(flicId).CurrentFrame = FlicItems(flicId).FrameCount - 1
    End If

    If FlicItems(flicId).CurrentFrame < 0 Then Exit Function

    If FlicEnsureRenderedFrame(flicId, FlicItems(flicId).CurrentFrame) = 0 Then Exit Function

    FlicRenderCurrentImage& = FlicItems(flicId).CanvasImage
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC save frame.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item; fileName = string holding a file path or a human-readable name.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicSaveFrame% (flicId As Long, frameIndex As Long, fileName As String)
    ' Variable: savedFrame stores the working value for saved frame.
    Dim savedFrame As Long

    FlicSaveFrame% = 0

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function
    If Len(fileName) = 0 Then Exit Function
    If FlicItems(flicId).CanvasImage > -2 Then Exit Function

    savedFrame = FlicItems(flicId).CurrentFrame

    If FlicEnsureRenderedFrame(flicId, frameIndex) = 0 Then Exit Function

    _SaveImage fileName, FlicItems(flicId).CanvasImage
    dim N as long
    FlicItems(flicId).CurrentFrame = savedFrame
    N = FlicEnsureRenderedFrame (flicId, savedFrame)

    FlicSaveFrame% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC clone frame image.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicCloneFrameImage& (flicId As Long, frameIndex As Long)
    ' Variable: savedFrame stores the working value for saved frame.
    Dim savedFrame As Long
    ' Variable: outHandle stores the handle used to reference an external or QB64 resource.
    Dim outHandle As Long

    FlicCloneFrameImage = -1
    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function
    If FlicItems(flicId).CanvasImage > -2 Then Exit Function

    savedFrame = FlicItems(flicId).CurrentFrame
    If FlicEnsureRenderedFrame(flicId, frameIndex) = 0 Then Exit Function
    If FlicItems(flicId).CanvasImage > -2 Then Exit Function

    outHandle = _CopyImage(FlicItems(flicId).CanvasImage, 32)
    dim N as long
    If savedFrame <> frameIndex Then
        FlicItems(flicId).CurrentFrame = savedFrame
        N = FlicEnsureRenderedFrame (flicId, savedFrame)
    End If

    FlicCloneFrameImage = outHandle
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC frame delay sec.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicFrameDelaySec# (flicId As Long, frameIndex As Long)
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double

    delaySec = FlicGetFrameDelay(flicId, frameIndex) / 1000#
    If delaySec <= 0 Then delaySec = .03
    FlicFrameDelaySec = delaySec
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC alloc slot.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicAllocSlot& ()
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long
    ' Variable: oldTop stores the working value for old top.
    Dim oldTop As Long
    ' Variable: newTop stores the working value for new top.
    Dim newTop As Long

    FlicAllocSlot& = -1

    ' Loop purpose: walk through every currently allocated element in FlicItems.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To UBound(FlicItems)
        If FlicItems(indexValue).Used = 0 Then
            FlicAllocSlot& = indexValue
            Exit Function
        End If
    Next indexValue

    oldTop = UBound(FlicItems)
    If FlicSlotCapacity <= oldTop Then
        If FlicSlotCapacity < 1 Then
            newTop = 7
        Else
            newTop = FlicSlotCapacity * 2 + 1
        End If
        ' dynamic array: FlicItems is resized here to hold the dynamic table that stores one record per live object handled by this module.
        ReDim _Preserve FlicItems(newTop) As FlicStore
        ' dynamic array: FlicFileNames is resized here to hold the parallel array that remembers the source filename for each active entry.
        ReDim _Preserve FlicFileNames(newTop) As String
        ' dynamic array: FlicErrorTexts is resized here to hold the text storage for the last human-readable error message.
        ReDim _Preserve FlicErrorTexts(newTop) As String
        ' dynamic array: FlicPaletteData is resized here to hold the palette storage or palette index used during indexed-color decoding.
        ReDim _Preserve FlicPaletteData(0 To 255, 0 To newTop) As RGBColorType
        ' dynamic array: FlicPalette32Data is resized here to hold the palette storage or palette index used during indexed-color decoding.
        ReDim _Preserve FlicPalette32Data(0 To 255, 0 To newTop) As _Unsigned Long
        FlicSlotCapacity = newTop
    End If

    FlicAllocSlot& = oldTop + 1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC set error.
' Parameters: flicId = working value for FLIC id; textValue = working value for text value.
Sub FlicSetError (flicId As Long, textValue As String)
    If flicId < 0 Then Exit Sub
    If flicId > UBound(FlicErrorTexts) Then Exit Sub
    FlicErrorTexts(flicId) = textValue
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC mark dirty rect.
' Parameters: flicId = working value for FLIC id; leftPx = working value for left px; topPx = working value for top px; rightPx = working value for right px; bottomPx = working value for bottom px.
Sub FlicMarkDirtyRect (flicId As Long, leftPx As Long, topPx As Long, rightPx As Long, bottomPx As Long)
    ' Variable: maxRight stores the maximum allowed right.
    Dim maxRight As Long
    ' Variable: maxBottom stores the maximum allowed bottom.
    Dim maxBottom As Long

    If FlicValidId(flicId) = 0 Then Exit Sub
    If leftPx > rightPx Then Exit Sub
    If topPx > bottomPx Then Exit Sub

    maxRight = FlicItems(flicId).WidthPx - 1
    maxBottom = FlicItems(flicId).HeightPx - 1
    If maxRight < 0 Then Exit Sub
    If maxBottom < 0 Then Exit Sub

    If leftPx < 0 Then leftPx = 0
    If topPx < 0 Then topPx = 0
    If rightPx > maxRight Then rightPx = maxRight
    If bottomPx > maxBottom Then bottomPx = maxBottom

    If leftPx > rightPx Then Exit Sub
    If topPx > bottomPx Then Exit Sub

    If FlicItems(flicId).DirtyValid = 0 Then
        FlicItems(flicId).DirtyLeft = leftPx
        FlicItems(flicId).DirtyTop = topPx
        FlicItems(flicId).DirtyRight = rightPx
        FlicItems(flicId).DirtyBottom = bottomPx
        FlicItems(flicId).DirtyValid = -1
    Else
        If leftPx < FlicItems(flicId).DirtyLeft Then FlicItems(flicId).DirtyLeft = leftPx
        If topPx < FlicItems(flicId).DirtyTop Then FlicItems(flicId).DirtyTop = topPx
        If rightPx > FlicItems(flicId).DirtyRight Then FlicItems(flicId).DirtyRight = rightPx
        If bottomPx > FlicItems(flicId).DirtyBottom Then FlicItems(flicId).DirtyBottom = bottomPx
    End If
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC mark dirty full frame.
' Parameters: flicId = working value for FLIC id.
Sub FlicMarkDirtyFullFrame (flicId As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub
    If FlicItems(flicId).WidthPx < 1 Then Exit Sub
    If FlicItems(flicId).HeightPx < 1 Then Exit Sub

    FlicMarkDirtyRect flicId, 0, 0, FlicItems(flicId).WidthPx - 1, FlicItems(flicId).HeightPx - 1
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC valid id.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicValidId% (flicId As Long)
    FlicValidId% = 0

    If flicId < 0 Then Exit Function
    If flicId > UBound(FlicItems) Then Exit Function
    If FlicItems(flicId).Used = 0 Then Exit Function

    FlicValidId% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC init slot.
' Parameters: flicId = working value for FLIC id.
Sub FlicInitSlot (flicId As Long)
    If flicId < 0 Then Exit Sub
    If flicId > UBound(FlicItems) Then Exit Sub

    FlicItems(flicId).Used = 0
    FlicItems(flicId).FormatType = ANIM_FORMAT_NONE
    FlicItems(flicId).WidthPx = 0
    FlicItems(flicId).HeightPx = 0
    FlicItems(flicId).FrameCount = 0
    FlicItems(flicId).DefaultDelayMS = 0
    FlicItems(flicId).CurrentFrame = 0
    FlicItems(flicId).DecodedFrame = -1
    FlicItems(flicId).Playing = 0
    FlicItems(flicId).Paused = 0
    FlicItems(flicId).Looping = -1
    FlicItems(flicId).LastTick = 0
    FlicItems(flicId).NextTick = 0
    FlicItems(flicId).CanvasImage = -1
    FlicItems(flicId).ImageDirty = 0
    FlicItems(flicId).PaletteDirty = 0
    FlicItems(flicId).DirtyValid = 0
    FlicItems(flicId).DirtyLeft = 0
    FlicItems(flicId).DirtyTop = 0
    FlicItems(flicId).DirtyRight = 0
    FlicItems(flicId).DirtyBottom = 0
    FlicItems(flicId).FileDataStart = 0
    FlicItems(flicId).FileDataSize = 0
    FlicItems(flicId).PixelStart = 0
    FlicItems(flicId).PixelCount = 0
    FlicItems(flicId).FrameInfoStart = 0
    FlicItems(flicId).HasRingFrame = 0
    FlicItems(flicId).RingFrameOffset64 = 0
    FlicItems(flicId).RingFrameSize64 = 0
    FlicItems(flicId).SnapshotMetaStart = 0
    FlicItems(flicId).SnapshotCount = 0
    FlicItems(flicId).SnapshotInterval = 0
    FlicFileNames(flicId) = ""
    FlicErrorTexts(flicId) = ""
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC clear active.
Sub FlicClearActive ()
    FlicDecodeContextId = -1
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC prepare active.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicPrepareActive% (flicId As Long)
    FlicPrepareActive% = 0

    If FlicValidId(flicId) = 0 Then Exit Function

    FlicDecodeContextId = flicId
    FlicPrepareActive% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC alloc file block.
' Parameters: byteCount = count used to size or iterate the current data set.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicAllocFileBlock& (byteCount As _Integer64)
    ' Variable: startIndex stores the index variable used to address the current item.
    Dim startIndex As Long
    ' Variable: neededTop stores the working value for needed top.
    Dim neededTop As Long
    ' Variable: newCapacity stores the working value for new capacity.
    Dim newCapacity As Long

    FlicAllocFileBlock& = -1

    If byteCount < 1 Then Exit Function
    If byteCount > 2147483647 Then Exit Function

    startIndex = FlicFileDataNext
    neededTop = startIndex + byteCount

    If neededTop > FlicFileDataCapacity Then
        newCapacity = FlicFileDataCapacity
        If newCapacity < 1 Then newCapacity = 65536
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicFileData is resized here to hold the buffer that holds raw, packed, or decoded byte data.
        ReDim _Preserve FlicFileData(newCapacity - 1) As _Unsigned _Byte
        FlicFileDataCapacity = newCapacity
    End If

    FlicAllocFileBlock& = startIndex
    FlicFileDataNext = neededTop
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC load whole file to ram.
' Parameters: fileNum = working value for file num; fileDataStart = buffer that holds raw, packed, or decoded byte data; fileSize = working value for file size.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicLoadWholeFileToRam% (fileNum As Integer, fileDataStart As Long, fileSize As _Integer64)
    ' Variable: fileMem stores the memory handle or memory-related helper value.
    Dim fileMem As _MEM
    ' Variable: chunkBytes stores the working value for chunk bytes.
    Dim chunkBytes As Long
    ' Variable: tailBytes stores the working value for tail bytes.
    Dim tailBytes As Long
    ' Variable: fullChunkCount stores the count used to size or iterate the current data set.
    Dim fullChunkCount As Long
    ' Variable: chunkIndex stores the index variable used to address the current item.
    Dim chunkIndex As Long
    ' Variable: writeOffset stores the working value for write offset.
    Dim writeOffset As _Integer64
    ' Variable: readPos stores the working value for read pos.
    Dim readPos As _Integer64
    ' Variable: chunkSize stores the size of the current chunk payload.
    Dim chunkSize As Long

    FlicLoadWholeFileToRam% = 0

    If fileNum = 0 Then Exit Function
    If fileDataStart < 0 Then Exit Function
    If fileSize < 1 Then Exit Function
    If fileSize > 2147483647 Then Exit Function

    chunkBytes = 262144
    If FlicEnsureIoChunkBuffer(chunkBytes) = 0 Then Exit Function

    fileMem = _Mem(FlicFileData())
    If _MemExists(fileMem) = 0 Then Exit Function

    fullChunkCount = fileSize \ chunkBytes
    tailBytes = fileSize Mod chunkBytes
    writeOffset = fileMem.OFFSET + fileDataStart
    readPos = 1

    ' Loop purpose: step through structured chunks in the current file block.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For chunkIndex = 1 To fullChunkCount
        Get #fileNum, readPos, FlicIoChunkData()
        _MemPut fileMem, writeOffset, FlicIoChunkData()
        writeOffset = writeOffset + chunkBytes
        readPos = readPos + chunkBytes
    Next chunkIndex

    If tailBytes > 0 Then
        chunkSize = tailBytes
        If FlicEnsureIoTailBuffer(chunkSize) = 0 Then
            If _MemExists(fileMem) Then _MemFree fileMem
            Exit Function
        End If
        Get #fileNum, readPos, FlicIoTailData()
        _MemPut fileMem, writeOffset, FlicIoTailData()
    End If

    If _MemExists(fileMem) Then _MemFree fileMem
    FlicLoadWholeFileToRam% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC alloc pixel block.
' Parameters: pixelCount = count used to size or iterate the current data set.
' Return value: the function result follows the success/failure or data-return convention used by this module.
