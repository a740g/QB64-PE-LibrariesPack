    ' Variable: startIndex stores the index variable used to address the current item.
    Dim startIndex As Long
    ' Variable: neededTop stores the working value for needed top.
    Dim neededTop As Long
    ' Variable: newCapacity stores the working value for new capacity.
    Dim newCapacity As Long

    FlicAllocPixelBlock& = -1
    If pixelCount < 1 Then Exit Function

    startIndex = FlicPixelDataNext
    neededTop = startIndex + pixelCount

    If neededTop > FlicPixelDataCapacity Then
        newCapacity = FlicPixelDataCapacity
        If newCapacity < 1 Then newCapacity = 65536
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicPixelData is resized here to hold the buffer that holds raw, packed, or decoded byte data.
        ReDim _Preserve FlicPixelData(newCapacity - 1) As _Unsigned _Byte
        FlicPixelDataCapacity = newCapacity
    End If

    FlicAllocPixelBlock& = startIndex
    FlicPixelDataNext = neededTop
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC alloc frame block.
' Parameters: frameCount = total number of frames available for the current animation.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicAllocFrameBlock& (frameCount As Long)
    ' Variable: startIndex stores the index variable used to address the current item.
    Dim startIndex As Long
    ' Variable: neededTop stores the working value for needed top.
    Dim neededTop As Long
    ' Variable: newCapacity stores the working value for new capacity.
    Dim newCapacity As Long

    FlicAllocFrameBlock& = -1
    If frameCount < 1 Then Exit Function

    startIndex = FlicFrameOffsetsNext
    neededTop = startIndex + frameCount

    If neededTop > FlicFrameOffsetsCapacity Then
        newCapacity = FlicFrameOffsetsCapacity
        If newCapacity < 1 Then newCapacity = 4096
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicFrameOffsets64 is resized here to hold the working value for FLIC frame offsets 64.
        ReDim _Preserve FlicFrameOffsets64(newCapacity - 1) As _Integer64
        FlicFrameOffsetsCapacity = newCapacity
    End If

    FlicAllocFrameBlock& = startIndex
    FlicFrameOffsetsNext = neededTop
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC count snapshots.
' Parameters: frameCount = total number of frames available for the current animation; intervalValue = working value for interval value.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicCountSnapshots& (frameCount As Long, intervalValue As Long)
    If frameCount < 1 Then
        FlicCountSnapshots = 0
        Exit Function
    End If

    If intervalValue < 1 Then intervalValue = 1
    FlicCountSnapshots = ((frameCount - 1) \ intervalValue) + 1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC alloc snapshot meta block.
' Parameters: snapshotCount = count used to size or iterate the current data set; pixelCount = count used to size or iterate the current data set.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicAllocSnapshotMetaBlock& (snapshotCount As Long, pixelCount As Long)
    ' Variable: startIndex stores the index variable used to address the current item.
    Dim startIndex As Long
    ' Variable: neededTop stores the working value for needed top.
    Dim neededTop As Long
    ' Variable: newCapacity stores the working value for new capacity.
    Dim newCapacity As Long
    ' Variable: paletteStart stores the palette storage or palette index used during indexed-color decoding.
    Dim paletteStart As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: snapshotIndex stores the index variable used to address the current item.
    Dim snapshotIndex As Long

    FlicAllocSnapshotMetaBlock = -1
    If snapshotCount < 1 Then Exit Function
    If pixelCount < 1 Then Exit Function

    startIndex = FlicSnapshotMetaNext
    neededTop = startIndex + snapshotCount
    If neededTop > FlicSnapshotMetaCapacity Then
        newCapacity = FlicSnapshotMetaCapacity
        If newCapacity < 1 Then newCapacity = 256
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicSnapshotMeta is resized here to hold the working value for FLIC snapshot meta.
        ReDim _Preserve FlicSnapshotMeta(newCapacity - 1) As FlicSnapshotStore
        FlicSnapshotMetaCapacity = newCapacity
    End If

    paletteStart = FlicSnapshotPaletteNext
    neededTop = paletteStart + snapshotCount
    If neededTop > FlicSnapshotPaletteCapacity Then
        newCapacity = FlicSnapshotPaletteCapacity
        If newCapacity < 1 Then newCapacity = 256
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicSnapshotPalette is resized here to hold the palette storage or palette index used during indexed-color decoding.
        ReDim _Preserve FlicSnapshotPalette(0 To 255, newCapacity - 1) As RGBColorType
        FlicSnapshotPaletteCapacity = newCapacity
    End If

    pixelStart = FlicSnapshotPixelsNext
    neededTop = pixelStart + snapshotCount * pixelCount
    If neededTop > FlicSnapshotPixelsCapacity Then
        newCapacity = FlicSnapshotPixelsCapacity
        If newCapacity < 1 Then newCapacity = 65536
        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While newCapacity < neededTop
            If newCapacity > 1073741823 Then
                newCapacity = neededTop
                Exit Do
            End If
            newCapacity = newCapacity * 2
        Loop
        ' dynamic array: FlicSnapshotPixels is resized here to hold the working value for FLIC snapshot pixels.
        ReDim _Preserve FlicSnapshotPixels(newCapacity - 1) As _Unsigned _Byte
        FlicSnapshotPixelsCapacity = newCapacity
    End If

    snapshotIndex = 0
    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While snapshotIndex < snapshotCount
        FlicSnapshotMeta(startIndex + snapshotIndex).Used = 0
        FlicSnapshotMeta(startIndex + snapshotIndex).FrameIndex = -1
        FlicSnapshotMeta(startIndex + snapshotIndex).PixelStart = pixelStart + snapshotIndex * pixelCount
        FlicSnapshotMeta(startIndex + snapshotIndex).PaletteIndex = paletteStart + snapshotIndex
        snapshotIndex = snapshotIndex + 1
    Loop

    FlicSnapshotMetaNext = startIndex + snapshotCount
    FlicSnapshotPaletteNext = paletteStart + snapshotCount
    FlicSnapshotPixelsNext = pixelStart + snapshotCount * pixelCount
    FlicAllocSnapshotMetaBlock = startIndex
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC snapshot slot index.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicSnapshotSlotIndex& (flicId As Long, frameIndex As Long)
    ' Variable: intervalValue stores the working value for interval value.
    Dim intervalValue As Long
    ' Variable: slotOffset stores the working value for slot offset.
    Dim slotOffset As Long

    FlicSnapshotSlotIndex = -1
    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function

    intervalValue = FlicItems(flicId).SnapshotInterval
    If intervalValue < 1 Then Exit Function
    If (frameIndex Mod intervalValue) <> 0 Then Exit Function

    slotOffset = frameIndex \ intervalValue
    If slotOffset < 0 Then Exit Function
    If slotOffset >= FlicItems(flicId).SnapshotCount Then Exit Function

    FlicSnapshotSlotIndex = FlicItems(flicId).SnapshotMetaStart + slotOffset
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC maybe store snapshot.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
Sub FlicMaybeStoreSnapshot (flicId As Long, frameIndex As Long)
    ' Variable: snapshotSlot stores the slot number inside the module-wide storage arrays.
    Dim snapshotSlot As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: snapshotPixelStart stores the working value for snapshot pixel start.
    Dim snapshotPixelStart As Long
    ' Variable: paletteIndex stores the index variable used to address the current item.
    Dim paletteIndex As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    If FlicValidId(flicId) = 0 Then Exit Sub

    snapshotSlot = FlicSnapshotSlotIndex(flicId, frameIndex)
    If snapshotSlot < 0 Then Exit Sub
    If FlicSnapshotMeta(snapshotSlot).Used Then Exit Sub

    pixelCount = FlicItems(flicId).PixelCount
    pixelStart = FlicItems(flicId).PixelStart
    snapshotPixelStart = FlicSnapshotMeta(snapshotSlot).PixelStart
    paletteIndex = FlicSnapshotMeta(snapshotSlot).PaletteIndex

    indexValue = 0
    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While indexValue < pixelCount
        FlicSnapshotPixels(snapshotPixelStart + indexValue) = FlicPixelData(pixelStart + indexValue)
        indexValue = indexValue + 1
    Loop

    indexValue = 0
    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While indexValue <= 255
        FlicSnapshotPalette(indexValue, paletteIndex) = FlicPaletteData(indexValue, flicId)
        indexValue = indexValue + 1
    Loop

    FlicSnapshotMeta(snapshotSlot).FrameIndex = frameIndex
    FlicSnapshotMeta(snapshotSlot).Used = -1
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC restore nearest snapshot.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item; restoredFrame = working value for restored frame.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicRestoreNearestSnapshot% (flicId As Long, frameIndex As Long, restoredFrame As Long)
    ' Variable: intervalValue stores the working value for interval value.
    Dim intervalValue As Long
    ' Variable: slotOffset stores the working value for slot offset.
    Dim slotOffset As Long
    ' Variable: snapshotSlot stores the slot number inside the module-wide storage arrays.
    Dim snapshotSlot As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: snapshotPixelStart stores the working value for snapshot pixel start.
    Dim snapshotPixelStart As Long
    ' Variable: paletteIndex stores the index variable used to address the current item.
    Dim paletteIndex As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long
    ' Variable: redValue stores the working value for red value.
    Dim redValue As Long
    ' Variable: greenValue stores the working value for green value.
    Dim greenValue As Long
    ' Variable: blueValue stores the working value for blue value.
    Dim blueValue As Long

    FlicRestoreNearestSnapshot = 0
    restoredFrame = -1

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function

    intervalValue = FlicItems(flicId).SnapshotInterval
    If intervalValue < 1 Then Exit Function

    slotOffset = frameIndex \ intervalValue
    If slotOffset >= FlicItems(flicId).SnapshotCount Then slotOffset = FlicItems(flicId).SnapshotCount - 1

    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While slotOffset >= 0
        snapshotSlot = FlicItems(flicId).SnapshotMetaStart + slotOffset
        If FlicSnapshotMeta(snapshotSlot).Used Then
            pixelCount = FlicItems(flicId).PixelCount
            pixelStart = FlicItems(flicId).PixelStart
            snapshotPixelStart = FlicSnapshotMeta(snapshotSlot).PixelStart
            paletteIndex = FlicSnapshotMeta(snapshotSlot).PaletteIndex

            indexValue = 0
            ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
            Do While indexValue < pixelCount
                FlicPixelData(pixelStart + indexValue) = FlicSnapshotPixels(snapshotPixelStart + indexValue)
                indexValue = indexValue + 1
            Loop

            indexValue = 0
            ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
            Do While indexValue <= 255
                FlicPaletteData(indexValue, flicId) = FlicSnapshotPalette(indexValue, paletteIndex)
                redValue = FlicPaletteData(indexValue, flicId).R
                greenValue = FlicPaletteData(indexValue, flicId).G
                blueValue = FlicPaletteData(indexValue, flicId).B
                FlicPalette32Data(indexValue, flicId) = _RGB32(redValue, greenValue, blueValue)
                indexValue = indexValue + 1
            Loop

            restoredFrame = FlicSnapshotMeta(snapshotSlot).FrameIndex
            FlicItems(flicId).DecodedFrame = restoredFrame
            FlicItems(flicId).CurrentFrame = restoredFrame
            FlicItems(flicId).ImageDirty = -1
            FlicItems(flicId).PaletteDirty = 0
            FlicItems(flicId).DirtyValid = 0
            FlicMarkDirtyFullFrame flicId
            FlicRestoreNearestSnapshot = -1
            Exit Function
        End If
        slotOffset = slotOffset - 1
    Loop
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ensure io chunk buffer.
' Parameters: requiredBytes = working value for required bytes.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicEnsureIoChunkBuffer% (requiredBytes As Long)
    FlicEnsureIoChunkBuffer% = 0
    If requiredBytes < 1 Then Exit Function
    If FlicIoChunkCapacity <> requiredBytes Then
        ' dynamic array: FlicIoChunkData is resized here to hold the buffer that holds raw, packed, or decoded byte data.
        ReDim FlicIoChunkData(requiredBytes - 1) As _Unsigned _Byte
        FlicIoChunkCapacity = requiredBytes
    End If
    FlicEnsureIoChunkBuffer% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ensure io tail buffer.
' Parameters: requiredBytes = working value for required bytes.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicEnsureIoTailBuffer% (requiredBytes As Long)
    FlicEnsureIoTailBuffer% = 0
    If requiredBytes < 1 Then Exit Function
    If FlicIoTailCapacity <> requiredBytes Then
        ' dynamic array: FlicIoTailData is resized here to hold the buffer that holds raw, packed, or decoded byte data.
        ReDim FlicIoTailData(requiredBytes - 1) As _Unsigned _Byte
        FlicIoTailCapacity = requiredBytes
    End If
    FlicEnsureIoTailBuffer% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ensure zero fill buffer.
' Parameters: requiredBytes = working value for required bytes.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicEnsureZeroFillBuffer% (requiredBytes As Long)
    FlicEnsureZeroFillBuffer% = 0
    If requiredBytes < 1 Then Exit Function
    If FlicZeroFillCapacity <> requiredBytes Then
        ' dynamic array: FlicZeroFillData is resized here to hold the buffer that holds raw, packed, or decoded byte data.
        ReDim FlicZeroFillData(requiredBytes - 1) As _Unsigned _Byte
        FlicZeroFillCapacity = requiredBytes
    End If
    FlicEnsureZeroFillBuffer% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ensure row 32 buffer.
' Parameters: pixelCount = count used to size or iterate the current data set.
Sub FlicEnsureRow32Buffer (pixelCount As Long)
    If pixelCount < 1 Then Exit Sub
    If pixelCount = FlicRow32Capacity Then Exit Sub

    ' dynamic array: FlicRow32Data is resized here to hold the buffer that holds raw, packed, or decoded byte data.
    ReDim FlicRow32Data(pixelCount - 1) As _Unsigned Long
    FlicRow32Capacity = pixelCount
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC set decode context.
' Parameters: flicId = working value for FLIC id.
Sub FlicSetDecodeContext (flicId As Long)
    FlicDecodeContextId = flicId
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC frame offset 64.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicFrameOffset64&& (flicId As Long, frameIndex As Long)
    FlicFrameOffset64&& = 0

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function

    FlicFrameOffset64&& = FlicFrameOffsets64(FlicItems(flicId).FrameInfoStart + frameIndex)
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC build frame index.
' Parameters: fileDataStart = buffer that holds raw, packed, or decoded byte data; fileSize = working value for file size; headerData = buffer that holds raw, packed, or decoded byte data; formatType = working value for format type; frameCount = total number of frames available for the current animation; frameStart = working value for frame start; additional parameters continue the same pattern.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBuildFrameIndex% (fileDataStart As Long, fileSize As _Integer64, headerData As FLICHeaderType, formatType As Long, frameCount As Long, frameStart As Long, hasRing As Integer, ringOffset As _Integer64, ringSize As _Integer64)
    ' Variable: frameOffset stores the working value for frame offset.
    Dim frameOffset As _Integer64
    ' Variable: frameSize stores the working value for frame size.
    Dim frameSize As _Integer64
    ' Variable: frameType stores the working value for frame type.
    Dim frameType As Long
    ' Variable: chunkCount stores the count used to size or iterate the current data set.
    Dim chunkCount As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    FlicBuildFrameIndex% = 0
    hasRing = 0
    ringOffset = 0
    ringSize = 0

    If frameCount < 1 Then Exit Function
    If fileDataStart < 0 Then Exit Function
    If fileSize < 128 Then Exit Function

    If formatType = ANIM_FORMAT_FLI Then
        frameOffset = 128
    Else
        frameOffset = headerData.OfFrame1
    End If

    ' Loop purpose: iterate through animation frames while building, seeking, or updating playback state.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To frameCount - 1
        If frameOffset + FRAME_HEADER_SIZE > fileSize Then Exit Function

        frameSize = FlicRamReadULong(fileDataStart, frameOffset)
        frameType = FlicRamReadUShort(fileDataStart, frameOffset + 4)
        chunkCount = FlicRamReadUShort(fileDataStart, frameOffset + 6)

        If frameSize < FRAME_HEADER_SIZE Then Exit Function
        If frameType <> FRAME_MAGIC Then Exit Function
        If frameOffset + frameSize > fileSize Then Exit Function

        FlicFrameOffsets64(frameStart + indexValue) = frameOffset
        frameOffset = frameOffset + frameSize
    Next indexValue

    If formatType = ANIM_FORMAT_FLC Then
        If frameOffset + FRAME_HEADER_SIZE <= fileSize Then
            frameSize = FlicRamReadULong(fileDataStart, frameOffset)
            frameType = FlicRamReadUShort(fileDataStart, frameOffset + 4)
            chunkCount = FlicRamReadUShort(fileDataStart, frameOffset + 6)

            If frameSize >= FRAME_HEADER_SIZE Then
                If frameType = FRAME_MAGIC Then
                    If frameOffset + frameSize <= fileSize Then
                        hasRing = -1
                        ringOffset = frameOffset
                        ringSize = frameSize
                    End If
                End If
            End If
        End If
    End If

    FlicBuildFrameIndex% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC reset decode state.
' Parameters: flicId = working value for FLIC id.
Sub FlicResetDecodeState (flicId As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub

    FlicSetDecodeContext flicId
    FlicResetPixels
    FlicResetPalette
    FlicItems(flicId).DecodedFrame = -1
    FlicItems(flicId).ImageDirty = -1
    FlicItems(flicId).PaletteDirty = -1
    FlicItems(flicId).DirtyValid = 0
    FlicMarkDirtyFullFrame flicId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
' Parameters: flicId = working value for FLIC id; frameOffset = working value for frame offset.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicApplyFrameAtOffset% (flicId As Long, frameOffset As _Integer64)
    ' Variable: frameSize stores the working value for frame size.
    Dim frameSize As _Integer64
    ' Variable: frameType stores the working value for frame type.
    Dim frameType As Long
    ' Variable: chunkCount stores the count used to size or iterate the current data set.
    Dim chunkCount As Long
    ' Variable: framePayloadSize stores the working value for frame payload size.
    Dim framePayloadSize As Long
    ' Variable: fileDataStart stores the buffer that holds raw, packed, or decoded byte data.
    Dim fileDataStart As Long
    ' Variable: fileSize stores the working value for file size.
    Dim fileSize As _Integer64

    FlicApplyFrameAtOffset% = 0

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameOffset < 0 Then Exit Function

    fileDataStart = FlicItems(flicId).FileDataStart
    fileSize = FlicItems(flicId).FileDataSize
    If fileDataStart < 0 Then Exit Function
    If fileSize < 1 Then Exit Function
    If frameOffset + FRAME_HEADER_SIZE > fileSize Then Exit Function

    FlicSetDecodeContext flicId

    frameSize = FlicRamReadULong(fileDataStart, frameOffset)
    frameType = FlicRamReadUShort(fileDataStart, frameOffset + 4)
    chunkCount = FlicRamReadUShort(fileDataStart, frameOffset + 6)

    If frameSize < FRAME_HEADER_SIZE Then Exit Function
    If frameType <> FRAME_MAGIC Then Exit Function
    If frameOffset + frameSize > fileSize Then Exit Function

    framePayloadSize = frameSize - FRAME_HEADER_SIZE
    FlicFrameViewStart = fileDataStart + frameOffset + FRAME_HEADER_SIZE
    FlicFrameViewPos = 0
    FlicFrameViewLimit = framePayloadSize

    FlicDecodeFrameChunks frameSize, chunkCount
    FlicApplyFrameAtOffset% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf seek.
' Parameters: positionValue = working value for position value.
Sub FlicBufSeek (positionValue As Long)
    If positionValue < 0 Then positionValue = 0
    If positionValue > FlicFrameViewLimit Then positionValue = FlicFrameViewLimit
    FlicFrameViewPos = positionValue
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf tell.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufTell& ()
    FlicBufTell& = FlicFrameViewPos
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf read u byte.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufReadUByte% ()
    If FlicFrameViewPos >= FlicFrameViewLimit Then
        FlicBufReadUByte% = 0
        Exit Function
    End If

    FlicBufReadUByte% = FlicFileData(FlicFrameViewStart + FlicFrameViewPos)
    FlicFrameViewPos = FlicFrameViewPos + 1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf read u short.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufReadUShort& ()
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As Long
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As Long

    b0 = FlicBufReadUByte
    b1 = FlicBufReadUByte

    FlicBufReadUShort& = b0 + b1 * 256
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf read u long.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufReadULong&& ()
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Integer64
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Integer64
    ' Variable: b2 stores the working value for b 2.
    Dim b2 As _Integer64
    ' Variable: b3 stores the working value for b 3.
    Dim b3 As _Integer64

    b0 = FlicBufReadUByte
    b1 = FlicBufReadUByte
    b2 = FlicBufReadUByte
    b3 = FlicBufReadUByte

    FlicBufReadULong&& = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf read s byte.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufReadSByte% ()
    ' Variable: valueData stores the buffer that holds raw, packed, or decoded byte data.
    Dim valueData As Long

    valueData = FlicBufReadUByte
    If valueData > 127 Then valueData = valueData - 256
    FlicBufReadSByte% = valueData
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC buf read short.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicBufReadShort% ()
    ' Variable: valueData stores the buffer that holds raw, packed, or decoded byte data.
    Dim valueData As Long

    valueData = FlicBufReadUShort
    If valueData > 32767 Then valueData = valueData - 65536
    FlicBufReadShort% = valueData
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ensure rendered frame.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicEnsureRenderedFrame% (flicId As Long, frameIndex As Long)
    FlicEnsureRenderedFrame% = 0

    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function

    If FlicItems(flicId).DecodedFrame = frameIndex Then
        FlicItems(flicId).CurrentFrame = frameIndex
        If FlicItems(flicId).ImageDirty Then
            FlicIndexedToImage flicId
            FlicItems(flicId).ImageDirty = 0
        End If
        FlicEnsureRenderedFrame% = -1
        Exit Function
    End If

    If frameIndex = FlicItems(flicId).DecodedFrame + 1 Then
        If FlicApplyFrameAtOffset(flicId, FlicFrameOffset64(flicId, frameIndex)) = 0 Then Exit Function
        FlicItems(flicId).DecodedFrame = frameIndex
        FlicItems(flicId).CurrentFrame = frameIndex
        FlicMaybeStoreSnapshot flicId, frameIndex
    Else
        FlicRebuildStateToFrame flicId, frameIndex
        If FlicItems(flicId).DecodedFrame <> frameIndex Then Exit Function
    End If

    FlicIndexedToImage flicId
    FlicItems(flicId).ImageDirty = 0
    FlicEnsureRenderedFrame% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC loop to start.
' Parameters: flicId = working value for FLIC id.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicLoopToStart% (flicId As Long)
    FlicLoopToStart% = 0

    If FlicValidId(flicId) = 0 Then Exit Function
    If FlicItems(flicId).FrameCount < 1 Then Exit Function

    If FlicItems(flicId).FormatType = ANIM_FORMAT_FLC Then
        If FlicItems(flicId).HasRingFrame Then
            If FlicApplyFrameAtOffset(flicId, FlicItems(flicId).RingFrameOffset64) Then
                FlicItems(flicId).CurrentFrame = 0
                FlicItems(flicId).DecodedFrame = 0
                FlicIndexedToImage flicId
                FlicItems(flicId).ImageDirty = 0
                FlicLoopToStart% = -1
                Exit Function
            End If
        End If
    End If

    FlicRebuildStateToFrame flicId, 0
    If FlicItems(flicId).DecodedFrame <> 0 Then Exit Function

    FlicIndexedToImage flicId
    FlicItems(flicId).ImageDirty = 0
    FlicLoopToStart% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC create render image.
' Parameters: widthPx = decoded image width in pixels; heightPx = decoded image height in pixels.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicCreateRenderImage& (widthPx As Long, heightPx As Long)
    ' Variable: handleValue stores the handle used to reference an external or QB64 resource.
    Dim handleValue As Long

    FlicCreateRenderImage& = -1
    handleValue = -1

    If widthPx < 1 Then Exit Function
    If heightPx < 1 Then Exit Function

    handleValue = _NewImage(widthPx, heightPx, 32)
    If handleValue = -1 Then Exit Function

    FlicCreateRenderImage& = handleValue
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ram read u byte.
' Parameters: fileDataStart = buffer that holds raw, packed, or decoded byte data; positionValue = working value for position value.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicRamReadUByte% (fileDataStart As Long, positionValue As _Integer64)
    If fileDataStart < 0 Then
        FlicRamReadUByte% = 0
        Exit Function
    End If

    FlicRamReadUByte% = FlicFileData(fileDataStart + positionValue)
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ram read u short.
' Parameters: fileDataStart = buffer that holds raw, packed, or decoded byte data; positionValue = working value for position value.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicRamReadUShort& (fileDataStart As Long, positionValue As _Integer64)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As Long
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As Long

    b0 = FlicRamReadUByte(fileDataStart, positionValue)
    b1 = FlicRamReadUByte(fileDataStart, positionValue + 1)

    FlicRamReadUShort& = b0 + b1 * 256
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC ram read u long.
' Parameters: fileDataStart = buffer that holds raw, packed, or decoded byte data; positionValue = working value for position value.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicRamReadULong&& (fileDataStart As Long, positionValue As _Integer64)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Integer64
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Integer64
    ' Variable: b2 stores the working value for b 2.
    Dim b2 As _Integer64
    ' Variable: b3 stores the working value for b 3.
    Dim b3 As _Integer64

    b0 = FlicRamReadUByte(fileDataStart, positionValue)
    b1 = FlicRamReadUByte(fileDataStart, positionValue + 1)
    b2 = FlicRamReadUByte(fileDataStart, positionValue + 2)
    b3 = FlicRamReadUByte(fileDataStart, positionValue + 3)

    FlicRamReadULong&& = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadUByte% (fileNum As Integer)
    ' Variable: valueData stores the buffer that holds raw, packed, or decoded byte data.
    Dim valueData As _Unsigned _Byte

    valueData = 0
    Get #fileNum, , valueData
    FlicReadUByte% = valueData
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadUShort& (fileNum As Integer)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As Long
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As Long

    b0 = FlicReadUByte(fileNum)
    b1 = FlicReadUByte(fileNum)

    FlicReadUShort& = b0 + b1 * 256
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadULong&& (fileNum As Integer)
    ' Variable: b0 stores the working value for b 0.
    Dim b0 As _Integer64
    ' Variable: b1 stores the working value for b 1.
    Dim b1 As _Integer64
    ' Variable: b2 stores the working value for b 2.
    Dim b2 As _Integer64
    ' Variable: b3 stores the working value for b 3.
    Dim b3 As _Integer64

    b0 = FlicReadUByte(fileNum)
    b1 = FlicReadUByte(fileNum)
    b2 = FlicReadUByte(fileNum)
    b3 = FlicReadUByte(fileNum)

    FlicReadULong&& = b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadSByte% (fileNum As Integer)
    ' Variable: valueData stores the buffer that holds raw, packed, or decoded byte data.
    Dim valueData As Long

    valueData = FlicReadUByte(fileNum)
    If valueData > 127 Then valueData = valueData - 256

    FlicReadSByte% = valueData
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadShort% (fileNum As Integer)
    ' Variable: valueData stores the buffer that holds raw, packed, or decoded byte data.
    Dim valueData As Long

    valueData = FlicReadUShort(fileNum)
    If valueData > 32767 Then valueData = valueData - 65536

    FlicReadShort% = valueData
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC convert speed to ms.
' Parameters: formatType = working value for format type; rawSpeed = working value for raw speed.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicConvertSpeedToMS& (formatType As Long, rawSpeed As _Unsigned Long)
    ' Variable: converted stores the working value for converted.
    Dim converted As _Unsigned Long

    converted = rawSpeed

    If formatType = ANIM_FORMAT_FLI Then
        If converted < 1 Then converted = 1
        converted = (converted * 1000) \ 70
        If converted < 1 Then converted = 1
    Else
        If converted < 1 Then converted = 1
    End If

    FlicConvertSpeedToMS& = converted
End Function

' Purpose: Read structured FLI/FLC chunks from the byte stream.
' Parameters: fileNum = working value for file num; headerData = buffer that holds raw, packed, or decoded byte data; formatType = working value for format type.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicReadHeaderFromFile% (fileNum As Integer, headerData As FLICHeaderType, formatType As Long)
    ' Variable: fileLength stores the working value for file length.
    Dim fileLength As _Integer64
    ' Variable: rawSpeed stores the working value for raw speed.
    Dim rawSpeed As _Unsigned Long
    ' Variable: rawSpeed16 stores the working value for raw speed 16.
    Dim rawSpeed16 As Long

    FlicReadHeaderFromFile% = 0
    formatType = ANIM_FORMAT_NONE
    fileLength = LOF(fileNum)
    rawSpeed = 0
    rawSpeed16 = 0

    If fileLength < 128 Then Exit Function

    Seek #fileNum, 1

    headerData.FileSize = FlicReadULong(fileNum)
    headerData.Magic = FlicReadUShort(fileNum)
    headerData.Frames = FlicReadUShort(fileNum)
    headerData.Width = FlicReadUShort(fileNum)
    headerData.Height = FlicReadUShort(fileNum)
    headerData.Depth = FlicReadUShort(fileNum)
    headerData.Flags = FlicReadUShort(fileNum)

    If headerData.Magic = FLI_MAGIC Then
        formatType = ANIM_FORMAT_FLI
        rawSpeed16 = FlicReadUShort(fileNum)
        rawSpeed = rawSpeed16
    ElseIf headerData.Magic = FLC_MAGIC Then
        formatType = ANIM_FORMAT_FLC
        rawSpeed = FlicReadULong(fileNum)
    Else
        Exit Function
    End If

    Seek #fileNum, 81
    headerData.OfFrame1 = FlicReadULong(fileNum)
    headerData.OfFrame2 = FlicReadULong(fileNum)

    If headerData.Width < 1 Then Exit Function
    If headerData.Height < 1 Then Exit Function
    If headerData.Frames < 1 Then Exit Function

    If formatType = ANIM_FORMAT_FLI Then
        If headerData.Depth = 0 Then headerData.Depth = 8
        If headerData.Depth <> 8 Then Exit Function
        headerData.OfFrame1 = 128
        headerData.OfFrame2 = 0
    Else
        If headerData.Depth <> 8 Then Exit Function
        If headerData.OfFrame1 = 0 Then headerData.OfFrame1 = 128
    End If

    If headerData.FileSize = 0 Then headerData.FileSize = fileLength
    headerData.SpeedMS = FlicConvertSpeedToMS(formatType, rawSpeed)

    FlicReadHeaderFromFile% = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC reset palette.
Sub FlicResetPalette ()
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    ' Loop purpose: use indexValue as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 0 To 255
        FlicSetPaletteEntry indexValue, indexValue, indexValue, indexValue
    Next indexValue
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC reset pixels.
Sub FlicResetPixels ()
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: pixelMem stores the memory handle or memory-related helper value.
    Dim pixelMem As _MEM
    ' Variable: chunkBytes stores the working value for chunk bytes.
    Dim chunkBytes As Long
    ' Variable: fullChunkCount stores the count used to size or iterate the current data set.
    Dim fullChunkCount As Long
    ' Variable: tailBytes stores the working value for tail bytes.
    Dim tailBytes As Long
    ' Variable: writeOffset stores the working value for write offset.
    Dim writeOffset As _Integer64
    ' Variable: chunkIndex stores the index variable used to address the current item.
    Dim chunkIndex As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    pixelStart = FlicItems(slotId).PixelStart
    pixelCount = FlicItems(slotId).PixelCount
    If pixelCount < 1 Then Exit Sub

    chunkBytes = 262144
    If pixelCount < chunkBytes Then chunkBytes = pixelCount
    If FlicEnsureZeroFillBuffer(chunkBytes) = 0 Then Exit Sub

    pixelMem = _Mem(FlicPixelData())
    If _MemExists(pixelMem) = 0 Then Exit Sub

    fullChunkCount = pixelCount \ chunkBytes
    tailBytes = pixelCount Mod chunkBytes
    writeOffset = pixelMem.OFFSET + pixelStart

    ' Loop purpose: step through structured chunks in the current file block.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For chunkIndex = 1 To fullChunkCount
        _MemPut pixelMem, writeOffset, FlicZeroFillData()
        writeOffset = writeOffset + chunkBytes
    Next chunkIndex

    If tailBytes > 0 Then
        If FlicEnsureIoTailBuffer(tailBytes) = 0 Then
            If _MemExists(pixelMem) Then _MemFree pixelMem
            Exit Sub
        End If
        ' Loop purpose: walk through a byte-oriented range while parsing or transforming packed data.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For indexValue = 0 To tailBytes - 1
            FlicIoTailData(indexValue) = 0
        Next indexValue
        _MemPut pixelMem, writeOffset, FlicIoTailData()
    End If

    If _MemExists(pixelMem) Then _MemFree pixelMem
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC set palette entry.
' Parameters: indexValue = working value for index value; redValue = working value for red value; greenValue = working value for green value; blueValue = working value for blue value.
Sub FlicSetPaletteEntry (indexValue As Long, redValue As Long, greenValue As Long, blueValue As Long)
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub
    If indexValue < 0 Then Exit Sub
    If indexValue > 255 Then Exit Sub

    FlicPaletteData(indexValue, slotId).R = redValue
    FlicPaletteData(indexValue, slotId).G = greenValue
    FlicPaletteData(indexValue, slotId).B = blueValue
    FlicPalette32Data(indexValue, slotId) = _RGB32(redValue, greenValue, blueValue)
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC indexed to image.
' Parameters: flicId = working value for FLIC id.
Sub FlicIndexedToImage (flicId As Long)
    ' Variable: imgMem stores the QB64 image handle used to store or draw decoded pixels.
    Dim imgMem As _MEM
    ' Variable: widthPx stores the decoded image width in pixels.
    Dim widthPx As Long
    ' Variable: heightPx stores the decoded image height in pixels.
    Dim heightPx As Long
    ' Variable: leftPx stores the working value for left px.
    Dim leftPx As Long
    ' Variable: topPx stores the working value for top px.
    Dim topPx As Long
    ' Variable: rightPx stores the working value for right px.
    Dim rightPx As Long
    ' Variable: bottomPx stores the working value for bottom px.
    Dim bottomPx As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: x stores the horizontal pixel or coordinate index.
    Dim x As Long
    ' Variable: rowWidth stores the width value used by this routine.
    Dim rowWidth As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: rowBaseIndex stores the index variable used to address the current item.
    Dim rowBaseIndex As Long
    ' Variable: rowPixelIndex stores the index variable used to address the current item.
    Dim rowPixelIndex As Long
    ' Variable: memOffset stores the memory handle or memory-related helper value.
    Dim memOffset As _Integer64
    ' Variable: memBaseOffset stores the memory handle or memory-related helper value.
    Dim memBaseOffset As _Integer64
    ' Variable: colorIndex stores the index variable used to address the current item.
    Dim colorIndex As Long
    ' Variable: neededBytes stores the working value for needed bytes.
    Dim neededBytes As _Integer64
    ' Variable: imageHandle stores the QB64 image handle used to store or draw decoded pixels.
    Dim imageHandle As Long

    If FlicValidId(flicId) = 0 Then Exit Sub

    imageHandle = FlicItems(flicId).CanvasImage
    If imageHandle > -2 Then Exit Sub

    widthPx = FlicItems(flicId).WidthPx
    heightPx = FlicItems(flicId).HeightPx
    If widthPx < 1 Then Exit Sub
    If heightPx < 1 Then Exit Sub

    neededBytes = CLng(FlicItems(flicId).PixelCount) * 4
    If neededBytes < 4 Then Exit Sub

    If FlicItems(flicId).PaletteDirty Then
        FlicItems(flicId).DirtyValid = 0
        FlicMarkDirtyFullFrame flicId
    End If

    If FlicItems(flicId).DirtyValid = 0 Then Exit Sub

    leftPx = FlicItems(flicId).DirtyLeft
    topPx = FlicItems(flicId).DirtyTop
    rightPx = FlicItems(flicId).DirtyRight
    bottomPx = FlicItems(flicId).DirtyBottom
    rowWidth = rightPx - leftPx + 1
    If rowWidth < 1 Then Exit Sub

    FlicEnsureRow32Buffer rowWidth

    pixelStart = FlicItems(flicId).PixelStart

    imgMem = _MemImage(imageHandle)
    If imgMem.SIZE < neededBytes Then
        _MemFree imgMem
        Exit Sub
    End If

    memBaseOffset = imgMem.OFFSET

    ' Loop purpose: iterate through image rows or vertical positions.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For y = topPx To bottomPx
        rowBaseIndex = pixelStart + y * widthPx + leftPx

        ' Loop purpose: iterate through image columns, pixels, or horizontal positions.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For x = 0 To rowWidth - 1
            rowPixelIndex = rowBaseIndex + x
            colorIndex = FlicPixelData(rowPixelIndex)
            FlicRow32Data(x) = FlicPalette32Data(colorIndex, flicId)
        Next x

        memOffset = memBaseOffset + (CLng(y) * widthPx + leftPx) * 4
        _MemPut imgMem, memOffset, FlicRow32Data()
    Next y

    _MemFree imgMem

    FlicItems(flicId).PaletteDirty = 0
    FlicItems(flicId).DirtyValid = 0
End Sub


' Purpose: Routine for the FLIC/FLC backend: handle FLIC rebuild state to frame.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
Sub FlicRebuildStateToFrame (flicId As Long, frameIndex As Long)
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long
    ' Variable: restoredFrame stores the working value for restored frame.
    Dim restoredFrame As Long

    If FlicValidId(flicId) = 0 Then Exit Sub
    If frameIndex < 0 Then Exit Sub
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Sub

    restoredFrame = -1
    If FlicRestoreNearestSnapshot(flicId, frameIndex, restoredFrame) = 0 Then
        FlicResetDecodeState flicId
        restoredFrame = -1
    End If

    indexValue = restoredFrame + 1
    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While indexValue <= frameIndex
        If FlicApplyFrameAtOffset(flicId, FlicFrameOffset64(flicId, indexValue)) = 0 Then Exit Sub
        FlicItems(flicId).DecodedFrame = indexValue
        FlicMaybeStoreSnapshot flicId, indexValue
        indexValue = indexValue + 1
    Loop

    FlicItems(flicId).CurrentFrame = frameIndex
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
' Parameters: frameOffset = working value for frame offset; frameSize = working value for frame size; chunkCount = count used to size or iterate the current data set.
Sub FlicDecodeFrameChunks (frameSize As _Integer64, chunkCount As Long)
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: indexValue stores the working value for index value.
    Dim indexValue As Long
    ' Variable: chunkSize stores the size of the current chunk payload.
    Dim chunkSize As _Integer64
    ' Variable: chunkType stores the working value for chunk type.
    Dim chunkType As Long
    ' Variable: chunkEndPosition stores the working value for chunk end position.
    Dim chunkEndPosition As Long
    ' Variable: frameEndPosition stores the working value for frame end position.
    Dim frameEndPosition As Long
    ' Variable: currentPosition stores the working value for current position.
    Dim currentPosition As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub
    If chunkCount < 0 Then Exit Sub
    If frameSize < FRAME_HEADER_SIZE Then Exit Sub
    If chunkCount = 0 Then Exit Sub

    frameEndPosition = FlicFrameViewLimit

    ' Loop purpose: step through structured chunks in the current file block.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For indexValue = 1 To chunkCount
        currentPosition = FlicBufTell
        If currentPosition + 6 > frameEndPosition Then Exit For

        chunkSize = FlicBufReadULong
        chunkType = FlicBufReadUShort

        If chunkSize < 6 Then Exit For

        chunkEndPosition = currentPosition + chunkSize
        If chunkEndPosition > frameEndPosition Then chunkEndPosition = frameEndPosition

        Select Case chunkType
            Case CHUNK_BLACK
                FlicDecodeChunkBlack

            Case CHUNK_COPY
                FlicDecodeChunkCopy chunkSize

            Case CHUNK_COLOR_256
                FlicDecodeChunkColor256 

            Case CHUNK_COLOR_64
                FlicDecodeChunkColor64 

            Case CHUNK_BYTE_RUN
                FlicDecodeChunkByteRun

            Case CHUNK_DELTA_FLI
                FlicDecodeChunkDeltaFLI

            Case CHUNK_DELTA_FLC
                If FlicItems(slotId).FormatType = ANIM_FORMAT_FLC Then
                    FlicDecodeChunkDeltaFLC
                End If

            Case CHUNK_PSTAMP
                ' skip

            Case Else
                ' skip unknown chunk
        End Select

        FlicSkipChunk chunkEndPosition
        If FlicBufTell >= frameEndPosition Then Exit For
    Next indexValue
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC skip chunk.
' Parameters: chunkEndPosition = working value for chunk end position.
Sub FlicSkipChunk (chunkEndPosition As _Integer64)
    If chunkEndPosition < 0 Then Exit Sub
    FlicBufSeek chunkEndPosition
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
Sub FlicDecodeChunkBlack ()
    FlicResetPixels
    FlicMarkDirtyFullFrame FlicDecodeContextId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
' Parameters: chunkSize = size of the current chunk payload.
Sub FlicDecodeChunkCopy (chunkSize As _Integer64)
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: pixelCount stores the count used to size or iterate the current data set.
    Dim pixelCount As Long
    ' Variable: dataSize stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataSize As _Integer64
    ' Variable: pixelIndex stores the index variable used to address the current item.
    Dim pixelIndex As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long
    ' Variable: dataPosition stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataPosition As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    pixelCount = FlicItems(slotId).PixelCount
    pixelStart = FlicItems(slotId).PixelStart
    dataSize = chunkSize - 6
    If dataSize < pixelCount Then Exit Sub

    dataPosition = FlicFrameViewPos

    ' Loop purpose: use pixelIndex as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For pixelIndex = 0 To pixelCount - 1
        FlicPixelData(pixelStart + pixelIndex) = FlicFileData(FlicFrameViewStart + dataPosition)
        dataPosition = dataPosition + 1
    Next pixelIndex

    FlicFrameViewPos = dataPosition
    FlicMarkDirtyFullFrame slotId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
' Parameters: chunkSize = size of the current chunk payload.
Sub FlicDecodeChunkColor256 
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: packetCount stores the count used to size or iterate the current data set.
    Dim packetCount As Long
    ' Variable: packetIndex stores the index variable used to address the current item.
    Dim packetIndex As Long
    ' Variable: skipCount stores the count used to size or iterate the current data set.
    Dim skipCount As Long
    ' Variable: copyCount stores the count used to size or iterate the current data set.
    Dim copyCount As Long
    ' Variable: colorIndex stores the index variable used to address the current item.
    Dim colorIndex As Long
    ' Variable: writeCount stores the count used to size or iterate the current data set.
    Dim writeCount As Long
    ' Variable: writeIndex stores the index variable used to address the current item.
    Dim writeIndex As Long
    ' Variable: redValue stores the working value for red value.
    Dim redValue As Long
    ' Variable: greenValue stores the working value for green value.
    Dim greenValue As Long
    ' Variable: blueValue stores the working value for blue value.
    Dim blueValue As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    packetCount = FlicBufReadUShort
    colorIndex = 0

    ' Loop purpose: use packetIndex as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For packetIndex = 1 To packetCount
        skipCount = FlicBufReadUByte
        copyCount = FlicBufReadUByte
        colorIndex = colorIndex + skipCount

        If copyCount = 0 Then
            writeCount = 256
        Else
            writeCount = copyCount
        End If

        ' Loop purpose: use writeIndex as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For writeIndex = 1 To writeCount
            redValue = FlicBufReadUByte
            greenValue = FlicBufReadUByte
            blueValue = FlicBufReadUByte

            If colorIndex >= 0 And colorIndex <= 255 Then
                FlicSetPaletteEntry colorIndex, redValue, greenValue, blueValue
            End If

            colorIndex = colorIndex + 1
        Next writeIndex
    Next packetIndex
    FlicItems(slotId).PaletteDirty = -1
    FlicMarkDirtyFullFrame slotId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
' Parameters: chunkSize = size of the current chunk payload.
Sub FlicDecodeChunkColor64
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: packetCount stores the count used to size or iterate the current data set.
    Dim packetCount As Long
    ' Variable: packetIndex stores the index variable used to address the current item.
    Dim packetIndex As Long
    ' Variable: skipCount stores the count used to size or iterate the current data set.
    Dim skipCount As Long
    ' Variable: copyCount stores the count used to size or iterate the current data set.
    Dim copyCount As Long
    ' Variable: colorIndex stores the index variable used to address the current item.
    Dim colorIndex As Long
    ' Variable: writeCount stores the count used to size or iterate the current data set.
    Dim writeCount As Long
    ' Variable: writeIndex stores the index variable used to address the current item.
    Dim writeIndex As Long
    ' Variable: redValue stores the working value for red value.
    Dim redValue As Long
    ' Variable: greenValue stores the working value for green value.
    Dim greenValue As Long
    ' Variable: blueValue stores the working value for blue value.
    Dim blueValue As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    packetCount = FlicBufReadUShort
    colorIndex = 0

    ' Loop purpose: use packetIndex as a counter/index while the routine processes a repeated set of values.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For packetIndex = 1 To packetCount
        skipCount = FlicBufReadUByte
        copyCount = FlicBufReadUByte
        colorIndex = colorIndex + skipCount

        If copyCount = 0 Then
            writeCount = 256
        Else
            writeCount = copyCount
        End If

        ' Loop purpose: use writeIndex as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For writeIndex = 1 To writeCount
            redValue = FlicBufReadUByte
            greenValue = FlicBufReadUByte
            blueValue = FlicBufReadUByte

            redValue = redValue * 4
            greenValue = greenValue * 4
            blueValue = blueValue * 4

            If redValue > 255 Then redValue = 255
            If greenValue > 255 Then greenValue = 255
            If blueValue > 255 Then blueValue = 255

            If colorIndex >= 0 And colorIndex <= 255 Then
                FlicSetPaletteEntry colorIndex, redValue, greenValue, blueValue
            End If

            colorIndex = colorIndex + 1
        Next writeIndex
    Next packetIndex
    FlicItems(slotId).PaletteDirty = -1
    FlicMarkDirtyFullFrame slotId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
Sub FlicDecodeChunkByteRun ()
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: x stores the horizontal pixel or coordinate index.
    Dim x As Long
    ' Variable: rowStart stores the row pointer, row buffer, or row index used for image processing.
    Dim rowStart As Long
    ' Variable: pixelIndex stores the index variable used to address the current item.
    Dim pixelIndex As Long
    ' Variable: packetCount stores the count used to size or iterate the current data set.
    Dim packetCount As Long
    ' Variable: countByte stores the count used to size or iterate the current data set.
    Dim countByte As Long
    ' Variable: signedCount stores the count used to size or iterate the current data set.
    Dim signedCount As Long
    ' Variable: literalCount stores the count used to size or iterate the current data set.
    Dim literalCount As Long
    ' Variable: repeatCount stores the count used to size or iterate the current data set.
    Dim repeatCount As Long
    ' Variable: dataByte stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataByte As Long
    ' Variable: copyIndex stores the index variable used to address the current item.
    Dim copyIndex As Long
    ' Variable: widthPx stores the decoded image width in pixels.
    Dim widthPx As Long
    ' Variable: heightPx stores the decoded image height in pixels.
    Dim heightPx As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    widthPx = FlicItems(slotId).WidthPx
    heightPx = FlicItems(slotId).HeightPx
    pixelStart = FlicItems(slotId).PixelStart

    ' Loop purpose: iterate through image rows or vertical positions.
    ' The loop order matters because later statements expect the data to be visited sequentially.
    For y = 0 To heightPx - 1
        packetCount = FlicBufReadUByte
        x = 0
        rowStart = pixelStart + y * widthPx

        ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
        Do While x < widthPx
            countByte = FlicBufReadUByte

            If countByte > 127 Then
                signedCount = countByte - 256
            Else
                signedCount = countByte
            End If

            If signedCount > 0 Then
                repeatCount = signedCount
                dataByte = FlicBufReadUByte

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To repeatCount
                    If x < widthPx Then
                        pixelIndex = rowStart + x
                        FlicPixelData(pixelIndex) = dataByte
                        x = x + 1
                    End If
                Next copyIndex

            ElseIf signedCount < 0 Then
                literalCount = -signedCount

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To literalCount
                    dataByte = FlicBufReadUByte

                    If x < widthPx Then
                        pixelIndex = rowStart + x
                        FlicPixelData(pixelIndex) = dataByte
                        x = x + 1
                    End If
                Next copyIndex
            End If
        Loop
    Next y
    FlicMarkDirtyFullFrame slotId
End Sub

' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
Sub FlicDecodeChunkDeltaFLI ()
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: skipLines stores the working value for skip lines.
    Dim skipLines As Long
    ' Variable: changeLines stores the working value for change lines.
    Dim changeLines As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: packetCount stores the count used to size or iterate the current data set.
    Dim packetCount As Long
    ' Variable: packetIndex stores the index variable used to address the current item.
    Dim packetIndex As Long
    ' Variable: skipCount stores the count used to size or iterate the current data set.
    Dim skipCount As Long
    ' Variable: sizeCount stores the count used to size or iterate the current data set.
    Dim sizeCount As Long
    ' Variable: literalCount stores the count used to size or iterate the current data set.
    Dim literalCount As Long
    ' Variable: repeatCount stores the count used to size or iterate the current data set.
    Dim repeatCount As Long
    ' Variable: dataByte stores the buffer that holds raw, packed, or decoded byte data.
    Dim dataByte As Long
    ' Variable: x stores the horizontal pixel or coordinate index.
    Dim x As Long
    ' Variable: rowStart stores the row pointer, row buffer, or row index used for image processing.
    Dim rowStart As Long
    ' Variable: pixelOffset stores the working value for pixel offset.
    Dim pixelOffset As Long
    ' Variable: copyIndex stores the index variable used to address the current item.
    Dim copyIndex As Long
    ' Variable: rowChanged stores the row pointer, row buffer, or row index used for image processing.
    Dim rowChanged As Integer
    ' Variable: rowDirtyLeft stores the row pointer, row buffer, or row index used for image processing.
    Dim rowDirtyLeft As Long
    ' Variable: rowDirtyRight stores the row pointer, row buffer, or row index used for image processing.
    Dim rowDirtyRight As Long
    ' Variable: rowWriteStart stores the row pointer, row buffer, or row index used for image processing.
    Dim rowWriteStart As Long
    ' Variable: rowWriteEnd stores the row pointer, row buffer, or row index used for image processing.
    Dim rowWriteEnd As Long
    ' Variable: widthPx stores the decoded image width in pixels.
    Dim widthPx As Long
    ' Variable: heightPx stores the decoded image height in pixels.
    Dim heightPx As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    widthPx = FlicItems(slotId).WidthPx
    heightPx = FlicItems(slotId).HeightPx
    pixelStart = FlicItems(slotId).PixelStart

    skipLines = FlicBufReadUShort
    changeLines = FlicBufReadUShort
    y = skipLines

    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While changeLines > 0
        If y >= heightPx Then Exit Do

        packetCount = FlicBufReadUByte
        x = 0
        rowStart = pixelStart + y * widthPx
        rowChanged = 0
        rowDirtyLeft = widthPx
        rowDirtyRight = -1

        ' Loop purpose: use packetIndex as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For packetIndex = 1 To packetCount
            skipCount = FlicBufReadUByte
            x = x + skipCount

            sizeCount = FlicBufReadSByte

            If sizeCount > 0 Then
                literalCount = sizeCount
                rowWriteStart = x
                rowWriteEnd = x + literalCount - 1

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To literalCount
                    dataByte = FlicBufReadUByte

                    If x < widthPx Then
                        pixelOffset = rowStart + x
                        FlicPixelData(pixelOffset) = dataByte
                    End If

                    x = x + 1
                Next copyIndex

                If rowWriteStart < widthPx Then
                    If rowWriteEnd >= widthPx Then rowWriteEnd = widthPx - 1
                    If rowWriteEnd >= rowWriteStart Then
                        If rowWriteStart < rowDirtyLeft Then rowDirtyLeft = rowWriteStart
                        If rowWriteEnd > rowDirtyRight Then rowDirtyRight = rowWriteEnd
                        rowChanged = -1
                    End If
                End If

            ElseIf sizeCount < 0 Then
                repeatCount = -sizeCount
                dataByte = FlicBufReadUByte
                rowWriteStart = x
                rowWriteEnd = x + repeatCount - 1

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To repeatCount
                    If x < widthPx Then
                        pixelOffset = rowStart + x
                        FlicPixelData(pixelOffset) = dataByte
                    End If

                    x = x + 1
                Next copyIndex

                If rowWriteStart < widthPx Then
                    If rowWriteEnd >= widthPx Then rowWriteEnd = widthPx - 1
                    If rowWriteEnd >= rowWriteStart Then
                        If rowWriteStart < rowDirtyLeft Then rowDirtyLeft = rowWriteStart
                        If rowWriteEnd > rowDirtyRight Then rowDirtyRight = rowWriteEnd
                        rowChanged = -1
                    End If
                End If
            End If
        Next packetIndex

        If rowChanged Then
            FlicMarkDirtyRect slotId, rowDirtyLeft, y, rowDirtyRight, y
        End If

        y = y + 1
        changeLines = changeLines - 1
    Loop
End Sub


' Purpose: Decode or apply FLI/FLC chunk data to the current frame buffer.
Sub FlicDecodeChunkDeltaFLC ()
    ' Variable: slotId stores the working value for slot id.
    Dim slotId As Long
    ' Variable: linesRemaining stores the working value for lines remaining.
    Dim linesRemaining As Long
    ' Variable: y stores the vertical pixel or coordinate index.
    Dim y As Long
    ' Variable: opcodeValue stores the working value for opcode value.
    Dim opcodeValue As Long
    ' Variable: opcodeType stores the working value for opcode type.
    Dim opcodeType As Long
    ' Variable: signedOpcode stores the working value for signed opcode.
    Dim signedOpcode As Long
    ' Variable: packetCount stores the count used to size or iterate the current data set.
    Dim packetCount As Long
    ' Variable: packetIndex stores the index variable used to address the current item.
    Dim packetIndex As Long
    ' Variable: skipCount stores the count used to size or iterate the current data set.
    Dim skipCount As Long
    ' Variable: rleCount stores the count used to size or iterate the current data set.
    Dim rleCount As Long
    ' Variable: repeatCount stores the count used to size or iterate the current data set.
    Dim repeatCount As Long
    ' Variable: wordValue stores the working value for word value.
    Dim wordValue As Long
    ' Variable: lowByte stores the working value for low byte.
    Dim lowByte As Long
    ' Variable: highByte stores the working value for high byte.
    Dim highByte As Long
    ' Variable: x stores the horizontal pixel or coordinate index.
    Dim x As Long
    ' Variable: rowStart stores the row pointer, row buffer, or row index used for image processing.
    Dim rowStart As Long
    ' Variable: pixelOffset stores the working value for pixel offset.
    Dim pixelOffset As Long
    ' Variable: copyIndex stores the index variable used to address the current item.
    Dim copyIndex As Long
    ' Variable: rowChanged stores the row pointer, row buffer, or row index used for image processing.
    Dim rowChanged As Integer
    ' Variable: rowDirtyLeft stores the row pointer, row buffer, or row index used for image processing.
    Dim rowDirtyLeft As Long
    ' Variable: rowDirtyRight stores the row pointer, row buffer, or row index used for image processing.
    Dim rowDirtyRight As Long
    ' Variable: rowWriteStart stores the row pointer, row buffer, or row index used for image processing.
    Dim rowWriteStart As Long
    ' Variable: rowWriteEnd stores the row pointer, row buffer, or row index used for image processing.
    Dim rowWriteEnd As Long
    ' Variable: widthPx stores the decoded image width in pixels.
    Dim widthPx As Long
    ' Variable: heightPx stores the decoded image height in pixels.
    Dim heightPx As Long
    ' Variable: pixelStart stores the working value for pixel start.
    Dim pixelStart As Long

    If FlicDecodeContextId < 0 Then Exit Sub

    slotId = FlicDecodeContextId
    If FlicValidId(slotId) = 0 Then Exit Sub

    widthPx = FlicItems(slotId).WidthPx
    heightPx = FlicItems(slotId).HeightPx
    pixelStart = FlicItems(slotId).PixelStart

    linesRemaining = FlicBufReadUShort
    y = 0

    ' Loop purpose: keep processing until the controlling condition becomes false, usually while input or timing remains active.
    Do While linesRemaining > 0
        rowChanged = 0
        rowDirtyLeft = widthPx
        rowDirtyRight = -1

        ' Loop purpose: repeat this block until an internal exit condition decides that the current stage is complete.
        Do
            opcodeValue = FlicBufReadUShort
            opcodeType = opcodeValue And DELTA_OPCODE_MASK

            If opcodeType = DELTA_OPCODE_PACKET Then
                packetCount = opcodeValue And DELTA_PACKET_MASK
                Exit Do
            End If

            If opcodeType = DELTA_OPCODE_LASTPIXEL Then
                If y >= 0 And y < heightPx Then
                    rowStart = pixelStart + y * widthPx
                    pixelOffset = rowStart + widthPx - 1
                    FlicPixelData(pixelOffset) = opcodeValue And 255
                    If widthPx > 0 Then
                        If widthPx - 1 < rowDirtyLeft Then rowDirtyLeft = widthPx - 1
                        If widthPx - 1 > rowDirtyRight Then rowDirtyRight = widthPx - 1
                        rowChanged = -1
                    End If
                End If

            ElseIf opcodeType = DELTA_OPCODE_LINESKIP Then
                signedOpcode = opcodeValue
                If signedOpcode > 32767 Then signedOpcode = signedOpcode - 65536

                If signedOpcode < 0 Then
                    y = y + (-signedOpcode)
                Else
                    Exit Sub
                End If

            Else
                Exit Sub
            End If
        Loop

        If y >= 0 And y < heightPx Then
            rowStart = pixelStart + y * widthPx
        Else
            rowStart = 0
        End If

        x = 0

        ' Loop purpose: use packetIndex as a counter/index while the routine processes a repeated set of values.
        ' The loop order matters because later statements expect the data to be visited sequentially.
        For packetIndex = 1 To packetCount
            skipCount = FlicBufReadUByte
            x = x + skipCount

            rleCount = FlicBufReadSByte

            If rleCount > 0 Then
                rowWriteStart = x
                rowWriteEnd = x + rleCount * 2 - 1

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To rleCount
                    wordValue = FlicBufReadUShort
                    lowByte = wordValue And 255
                    highByte = (wordValue \ 256) And 255

                    If y >= 0 And y < heightPx Then
                        If x < widthPx Then
                            pixelOffset = rowStart + x
                            FlicPixelData(pixelOffset) = lowByte
                        End If
                        x = x + 1

                        If x < widthPx Then
                            pixelOffset = rowStart + x
                            FlicPixelData(pixelOffset) = highByte
                        End If
                        x = x + 1
                    Else
                        x = x + 2
                    End If
                Next copyIndex

                If y >= 0 And y < heightPx Then
                    If rowWriteStart < widthPx Then
                        If rowWriteEnd >= widthPx Then rowWriteEnd = widthPx - 1
                        If rowWriteEnd >= rowWriteStart Then
                            If rowWriteStart < rowDirtyLeft Then rowDirtyLeft = rowWriteStart
                            If rowWriteEnd > rowDirtyRight Then rowDirtyRight = rowWriteEnd
                            rowChanged = -1
                        End If
                    End If
                End If

            ElseIf rleCount < 0 Then
                repeatCount = -rleCount
                wordValue = FlicBufReadUShort
                lowByte = wordValue And 255
                highByte = (wordValue \ 256) And 255
                rowWriteStart = x
                rowWriteEnd = x + repeatCount * 2 - 1

                ' Loop purpose: use copyIndex as a counter/index while the routine processes a repeated set of values.
                ' The loop order matters because later statements expect the data to be visited sequentially.
                For copyIndex = 1 To repeatCount
                    If y >= 0 And y < heightPx Then
                        If x < widthPx Then
                            pixelOffset = rowStart + x
                            FlicPixelData(pixelOffset) = lowByte
                        End If
                        x = x + 1

                        If x < widthPx Then
                            pixelOffset = rowStart + x
                            FlicPixelData(pixelOffset) = highByte
                        End If
                        x = x + 1
                    Else
                        x = x + 2
                    End If
                Next copyIndex

                If y >= 0 And y < heightPx Then
                    If rowWriteStart < widthPx Then
                        If rowWriteEnd >= widthPx Then rowWriteEnd = widthPx - 1
                        If rowWriteEnd >= rowWriteStart Then
                            If rowWriteStart < rowDirtyLeft Then rowDirtyLeft = rowWriteStart
                            If rowWriteEnd > rowDirtyRight Then rowDirtyRight = rowWriteEnd
                            rowChanged = -1
                        End If
                    End If
                End If
            End If
        Next packetIndex

        If rowChanged Then
            FlicMarkDirtyRect slotId, rowDirtyLeft, y, rowDirtyRight, y
        End If

        y = y + 1
        linesRemaining = linesRemaining - 1
    Loop
End Sub


' Purpose: Seek to a specific FLI/FLC frame or time position.
' Parameters: flicId = working value for FLIC id; frameIndex = index variable used to address the current item.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicSeekFrame% (flicId As Long, frameIndex As Long)
    ' Variable: nowValue stores the working value for now value.
    Dim nowValue As Double
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double

    FlicSeekFrame = 0
    If FlicValidId(flicId) = 0 Then Exit Function
    If frameIndex < 0 Then Exit Function
    If frameIndex >= FlicItems(flicId).FrameCount Then Exit Function

    If FlicEnsureRenderedFrame(flicId, frameIndex) = 0 Then Exit Function

    delaySec = FlicGetFrameDelay(flicId, frameIndex) / 1000#
    If delaySec <= 0 Then delaySec = .03

    nowValue = Timer
    FlicItems(flicId).CurrentFrame = frameIndex

    If FlicItems(flicId).Playing Then
        If FlicItems(flicId).Paused Then
            FlicItems(flicId).RemainingDelay = delaySec
            FlicItems(flicId).LastRawTimer = nowValue
        Else
            FlicItems(flicId).LastTick = nowValue
            FlicItems(flicId).LastRawTimer = nowValue
            FlicItems(flicId).NextTick = FlicTimeAdd(nowValue, delaySec)
            FlicItems(flicId).RemainingDelay = 0
        End If
    Else
        FlicItems(flicId).NextTick = 0
        FlicItems(flicId).RemainingDelay = 0
        FlicItems(flicId).LastRawTimer = 0
    End If

    FlicSeekFrame = -1
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC elapsed since.
' Parameters: previousTime = time-related value used by the current routine; currentTime = time-related value used by the current routine.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicElapsedSince# (previousTime As Double, currentTime As Double)
    ' Variable: elapsedSec stores the working value for elapsed sec.
    Dim elapsedSec As Double

    ' Keep the midnight wrap behavior intact while measuring TIMER progress.
    elapsedSec = currentTime - previousTime
    If elapsedSec < 0 Then elapsedSec = elapsedSec + 86400#

    FlicElapsedSince = elapsedSec
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC clock jump limit.
' Parameters: flicId = working value for FLIC id; previousTime = time-related value used by the current routine.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicClockJumpLimit# (flicId As Long, previousTime As Double)
    ' Variable: limitSec stores the working value for limit sec.
    Dim limitSec As Double

    limitSec = FlicTimeRemaining(FlicItems(flicId).NextTick, previousTime)
    If limitSec <= 0 Then
        limitSec = FlicGetFrameDelay(flicId, FlicItems(flicId).CurrentFrame) / 1000#
        If limitSec <= 0 Then limitSec = .03
    End If

    ' Allow ordinary frame jitter, but treat large raw TIMER jumps as a resync event.
    limitSec = limitSec + 1#
    If limitSec < 2# Then limitSec = 2#
    If limitSec > 10# Then limitSec = 10#

    FlicClockJumpLimit = limitSec
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC clock jumped.
' Parameters: flicId = working value for FLIC id; previousTime = time-related value used by the current routine; currentTime = time-related value used by the current routine.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicClockJumped% (flicId As Long, previousTime As Double, currentTime As Double)
    ' Variable: jumpFlag stores the working value for jump flag.
    Dim jumpFlag As Integer
    ' Variable: elapsedSec stores the working value for elapsed sec.
    Dim elapsedSec As Double
    ' Variable: limitSec stores the working value for limit sec.
    Dim limitSec As Double

    jumpFlag = 0
    elapsedSec = FlicElapsedSince(previousTime, currentTime)
    limitSec = FlicClockJumpLimit(flicId, previousTime)
    If elapsedSec > limitSec Then jumpFlag = -1

    FlicClockJumped = jumpFlag
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC resync after clock jump.
' Parameters: flicId = working value for FLIC id; currentTime = time-related value used by the current routine.
Sub FlicResyncAfterClockJump (flicId As Long, currentTime As Double)
    ' Variable: delaySec stores the frame delay or timing value.
    Dim delaySec As Double
    ' Variable: previousTime stores the time-related value used by the current routine.
    Dim previousTime As Double

    If FlicValidId(flicId) = 0 Then Exit Sub

    ' Re-anchor the current frame after a manual clock change or large TIMER discontinuity.
    previousTime = FlicItems(flicId).LastRawTimer
    delaySec = FlicTimeRemaining(FlicItems(flicId).NextTick, previousTime)
    If delaySec <= 0 Then
        delaySec = FlicGetFrameDelay(flicId, FlicItems(flicId).CurrentFrame) / 1000#
        If delaySec <= 0 Then delaySec = .03
    End If

    FlicItems(flicId).LastTick = currentTime
    FlicItems(flicId).NextTick = FlicTimeAdd(currentTime, delaySec)
    FlicItems(flicId).LastRawTimer = currentTime
End Sub

' Purpose: Routine for the FLIC/FLC backend: handle FLIC time add.
' Parameters: baseTime = time-related value used by the current routine; deltaSec = working value for delta sec.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicTimeAdd# (baseTime As Double, deltaSec As Double)
    ' Variable: resultTime stores the time-related value used by the current routine.
    Dim resultTime As Double

    ' Add seconds to a TIMER value and wrap across midnight.
    ' QB64PE should not use the function name inside expressions here.
    resultTime = baseTime + deltaSec
    If resultTime >= 86400# Then resultTime = resultTime - 86400#

    FlicTimeAdd = resultTime
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC time remaining.
' Parameters: targetTime = time-related value used by the current routine; currentTime = time-related value used by the current routine.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicTimeRemaining# (targetTime As Double, currentTime As Double)
    ' Variable: resultTime stores the time-related value used by the current routine.
    Dim resultTime As Double
    ' Variable: reachedFlag stores the working value for reached flag.
    Dim reachedFlag As Integer

    ' Preserve the leftover part of the current frame when pause is pressed.
    ' Use a local variable so the function name is only assigned at the end.
    resultTime = 0
    reachedFlag = FlicTimerReached(targetTime, currentTime)
    If reachedFlag Then
        FlicTimeRemaining = resultTime
        Exit Function
    End If

    resultTime = targetTime - currentTime
    If resultTime < 0 Then resultTime = resultTime + 86400#

    FlicTimeRemaining = resultTime
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC timer reached.
' Parameters: targetTime = time-related value used by the current routine; currentTime = time-related value used by the current routine.
' Return value: the function result follows the success/failure or data-return convention used by this module.
Function FlicTimerReached% (targetTime As Double, currentTime As Double)
    ' Variable: reachedFlag stores the working value for reached flag.
    Dim reachedFlag As Integer

    ' Use a local variable so the function name is only assigned at the end.
    reachedFlag = 0

    If currentTime >= targetTime Then
        reachedFlag = -1
    ElseIf targetTime - currentTime > 43200# Then
        reachedFlag = -1
    End If

    FlicTimerReached = reachedFlag
End Function

' Purpose: Routine for the FLIC/FLC backend: handle FLIC make default stop state.
' Parameters: flicId = working value for FLIC id.
Sub FlicMakeDefaultStopState (flicId As Long)
    If FlicValidId(flicId) = 0 Then Exit Sub

    FlicItems(flicId).Playing = 0
    FlicItems(flicId).Paused = 0
    FlicItems(flicId).CurrentFrame = 0
    FlicItems(flicId).LastTick = 0
    FlicItems(flicId).NextTick = 0
    FlicItems(flicId).RemainingDelay = 0
    FlicItems(flicId).LastRawTimer = 0
    FlicResetDecodeState flicId
End Sub
